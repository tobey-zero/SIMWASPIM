    <!DOCTYPE html>
    <html lang="id">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
        <meta http-equiv="Pragma" content="no-cache">
        <meta http-equiv="Expires" content="0">
        <title>KRISNA - <%= departmentName %></title>
        <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    </head>
    <body class="page-klinik">
        <header class="header">
            <div class="header-content">
                <div class="logo-section">
                    <div class="logo" style="cursor: pointer;">
                        <img src="/images/Logo.jpeg" alt="Logo" style="width: 100%; height: 100%; object-fit: contain; display: block;">
                    </div>
                    <div class="header-info">
                        <h2>KETERBUKAAN INFORMASI - <%= departmentName %></h2>
                        <h3>LAPAS KELAS 1 MEDAN</h3>
                        <p class="address">Jl. Lembaga Pemasyarakatan No.27, Tj. Gusta, Kec. Medan Helvetia, Kota Medan, Sumatera Utara 20125</p>
                    </div>
                </div>
                <div class="stats">
                    <div class="stat-item bebas">
                        <div class="stat-label">Tanggal</div>
                        <div class="stat-value"><%= tanggal %></div>
                    </div>
                </div>
            </div>
        </header>

        <div class="main-container" style="display:flex; flex-direction:column; gap:20px; padding:20px;">
            <% panels.forEach(panel => { %>
                <div class="panel">
                    <div class="panel-header <%= panel.color || 'red' %>"><%= panel.title %></div>
                    <div class="panel-content">
                        <% if (panel.type === 'table') { %>
                            <table style="width:100%; border-collapse:collapse; text-align:left;">
                                <thead>
                                    <tr>
                                        <% panel.headers.forEach(head => { %>
                                            <th style="padding:10px; background:#f8fafc; border-bottom:2px solid #e2e8f0; font-weight:600;"><%= head %></th>
                                        <% }) %>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% panel.rows.forEach(row => { %>
                                        <tr>
                                            <% row.forEach(cell => { %>
                                                <td style="padding:10px; border-bottom:1px solid #e2e8f0;"><%- cell || '-' %></td>
                                            <% }) %>
                                        </tr>
                                    <% }) %>
                                    <% if (panel.rows.length === 0) { %>
                                        <tr><td colspan="<%= panel.headers.length %>" style="padding:10px; text-align:center;">Tidak ada data</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        <% } else if (panel.type === 'custom') { %>
                            <%- panel.html %>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

        <footer class="footer">
            <div class="footer-running">
                <div class="footer-running-track">
                    <span><%= kataBijak %></span>
                </div>
            </div>
            <div class="footer-bottom" style="display: flex; justify-content: space-between; align-items: center; text-align: left;">
                <p style="flex: 1; max-width: 60%;"><strong>KRISNA</strong> - Tampilan <%= departmentName %> Warga Binaan.</p>
                <p style="text-align: right; flex: 1;">Keterbukaan Informasi Warga Binaan<br>Copyright &copy; <%= new Date().getFullYear() %></p>
            </div>
        </footer>
        <script src="/js/display-mode.js?v=<%= Date.now() %>"></script>
    </body>
    </html>
