<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dapur - Kalapas</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
  <style>
    .dapur-wrap { padding: 14px 15px; }
    .dapur-toolbar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 10px;
    }
    .dapur-toolbar a {
      text-decoration: none;
      color: #fff;
      background: #1a4bb8;
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 6px;
      padding: 7px 11px;
      font-size: 12px;
      font-weight: bold;
    }
    .dapur-submenu {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .dapur-submenu a {
      text-decoration: none;
      border: 1px solid #93c5fd;
      color: #1e3a8a;
      background: #eff6ff;
      border-radius: 6px;
      padding: 7px 11px;
      font-size: 12px;
      font-weight: bold;
    }
    .dapur-submenu a.active {
      color: #fff;
      background: #1a4bb8;
      border-color: rgba(255,255,255,.3);
    }
    .dapur-filter {
      padding: 10px;
      display: flex;
      align-items: end;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: space-between;
    }
    .dapur-filter form {
      display: flex;
      gap: 8px;
      align-items: end;
      flex-wrap: wrap;
    }
    .dapur-filter .label {
      font-size: 11px;
      color: #334155;
      font-weight: bold;
      margin-bottom: 3px;
      display: block;
    }
    .dapur-filter input[type="date"] {
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      padding: 7px 10px;
      font-size: 12px;
      font-weight: 700;
      color: #0f172a;
      background: #fff;
    }
    .dapur-filter button, .dapur-filter .reset {
      text-decoration: none;
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 6px;
      padding: 7px 11px;
      font-size: 12px;
      font-weight: bold;
      cursor: pointer;
    }
    .dapur-filter button {
      color: #fff;
      background: #1a4bb8;
    }
    .dapur-filter .reset {
      color: #1e3a8a;
      background: #eff6ff;
      border-color: #cbd5e1;
      display: inline-flex;
      align-items: center;
    }
    .dapur-meta {
      font-size: 12px;
      color: #475569;
      font-weight: 700;
    }
    .dapur-table td, .dapur-table th { font-size: 12px; }
    .dapur-photo {
      width: 56px;
      height: 56px;
      object-fit: cover;
      border-radius: 8px;
      border: 1px solid #dbeafe;
      display: block;
      cursor: zoom-in;
    }
    .dapur-photo-placeholder {
      width: 56px;
      height: 56px;
      border-radius: 8px;
      border: 1px solid #dbeafe;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #94a3b8;
      font-size: 12px;
      font-weight: bold;
      background: #f8fafc;
    }
    .dapur-empty {
      text-align: center;
      color: #64748b;
      padding: 16px;
      font-weight: bold;
    }

    .dapur-photo-lightbox {
      position: fixed;
      inset: 0;
      background: rgba(2, 6, 23, 0.86);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      padding: 24px;
    }

    .dapur-photo-lightbox.is-open {
      display: flex;
    }

    .dapur-photo-lightbox img {
      max-width: min(92vw, 1100px);
      max-height: 88vh;
      width: auto;
      height: auto;
      border-radius: 10px;
      box-shadow: 0 18px 44px rgba(0, 0, 0, 0.42);
      background: #fff;
    }

    .dapur-photo-lightbox .close-btn {
      position: absolute;
      top: 18px;
      right: 20px;
      width: 38px;
      height: 38px;
      border: 0;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.2);
      color: #fff;
      font-size: 26px;
      line-height: 1;
      cursor: pointer;
    }

    .dapur-photo-lightbox .close-btn:hover {
      background: rgba(255, 255, 255, 0.35);
    }
  </style>
</head>
<body class="page-umum">
  <header class="header">
    <div class="header-content">
      <div class="logo-section">
        <div class="logo kalapas-logo">
          <img src="/images/simwaspim.jpeg" alt="Logo SIMWASPIM" class="kalapas-logo-img">
        </div>
        <div class="header-info">
          <h1>SIMWASPIM – SISTEM PENGAWASAN PIMPINAN</h1>
          <h3>LAPAS KELAS 1 MEDAN</h3>
        </div>
      </div>
    </div>
  </header>

  <div class="dapur-wrap">
    <div class="dapur-toolbar">
      <a href="<%= backUrl %>">⬅ Kembali ke Dashboard Kalapas</a>
    </div>

    <div class="dapur-submenu">
      <a href="/kalapas/table/dapur?tab=menu&tanggal=<%= encodeURIComponent(selectedDate) %>" class="<%= activeTab === 'menu' ? 'active' : '' %>">🍽 Menu</a>
      <a href="/kalapas/table/dapur?tab=jadwal&tanggal=<%= encodeURIComponent(selectedDate) %>" class="<%= activeTab === 'jadwal' ? 'active' : '' %>">👨‍🍳 Jadwal Petugas</a>
      <a href="/kalapas/table/dapur?tab=distribusi&tanggal=<%= encodeURIComponent(selectedDate) %>" class="<%= activeTab === 'distribusi' ? 'active' : '' %>">📦 Distribusi Makanan</a>
      <a href="/kalapas/table/dapur?tab=permintaan&tanggal=<%= encodeURIComponent(selectedDate) %>" class="<%= activeTab === 'permintaan' ? 'active' : '' %>">📄 Permintaan Bahan Makanan</a>
      <a href="/kalapas/table/dapur?tab=diterima&tanggal=<%= encodeURIComponent(selectedDate) %>" class="<%= activeTab === 'diterima' ? 'active' : '' %>">📥 Penerimaan Bahan Makanan</a>
      <a href="/kalapas/table/dapur?tab=penyimpanan&tanggal=<%= encodeURIComponent(selectedDate) %>" class="<%= activeTab === 'penyimpanan' ? 'active' : '' %>">🏪 Penyimpanan Bahan Makanan</a>
    </div>

    <div class="panel">
      <div class="panel-header"><%= activeTab === 'jadwal' ? 'JADWAL PETUGAS DAPUR' : (activeTab === 'distribusi' ? 'DISTRIBUSI MAKANAN' : (activeTab === 'permintaan' ? 'PERMINTAAN BAHAN MAKANAN' : (activeTab === 'diterima' ? 'PENERIMAAN BAHAN MAKANAN' : (activeTab === 'penyimpanan' ? 'PENYIMPANAN BAHAN MAKANAN' : 'INFORMASI DAPUR')))) %></div>
      <% if (activeTab === 'menu') { %>
        <div class="dapur-filter">
          <form method="GET" action="/kalapas/table/dapur">
            <input type="hidden" name="tab" value="menu">
            <div>
              <span class="label">Tanggal Menu</span>
              <input type="date" name="tanggal" value="<%= selectedDate %>">
            </div>
            <button type="submit">📅 Tampilkan</button>
            <a href="/kalapas/table/dapur?tab=menu" class="reset">↺ Hari Ini</a>
          </form>
          <div class="dapur-meta">
            <div><strong><%= menuTitle %></strong></div>
            <div>Tanggal aktif: <%= selectedDateLabel %> | Total tanggal tersimpan: <%= totalHistory %></div>
          </div>
        </div>

        <div class="panel-content" style="padding-top:0;">
          <table class="data-table dapur-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Foto</th>
                <th>Waktu</th>
                <th>Menu Makanan</th>
              </tr>
            </thead>
            <tbody>
              <% menuList.forEach((item, idx) => { %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td>
                    <% if (item.photoPath) { %>
                      <img src="<%= item.photoPath %>" alt="Foto menu" class="dapur-photo">
                    <% } else { %>
                      <div class="dapur-photo-placeholder">-</div>
                    <% } %>
                  </td>
                  <td><%= item.waktu || '-' %></td>
                  <td style="white-space:pre-line;"><%= item.menu || '-' %></td>
                </tr>
              <% }) %>
              <% if (!menuList.length) { %>
                <tr><td colspan="4" class="dapur-empty">Belum ada menu pada tanggal ini</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } else if (activeTab === 'jadwal') { %>
        <div class="dapur-filter">
          <form method="GET" action="/kalapas/table/dapur">
            <input type="hidden" name="tab" value="jadwal">
            <div>
              <span class="label">Tanggal Jadwal</span>
              <input type="date" name="tanggal" value="<%= selectedDate %>">
            </div>
            <button type="submit">📅 Tampilkan</button>
            <a href="/kalapas/table/dapur?tab=jadwal" class="reset">↺ Hari Ini</a>
          </form>
          <div class="dapur-meta">
            <div><strong>JADWAL PETUGAS DAPUR / HARI</strong></div>
            <div>Tanggal aktif: <%= selectedDateLabel %> | Total tanggal jadwal tersimpan: <%= totalJadwalHistory %></div>
          </div>
        </div>

        <div class="panel-content" style="padding-top:0;">
          <table class="data-table dapur-table">
            <thead>
              <tr>
                <th>#</th>
                <th>NIP</th>
                <th>Nama</th>
                <th>Jabatan</th>
                <th>Deskripsi Tugas</th>
              </tr>
            </thead>
            <tbody>
              <% jadwalPetugasList.forEach((item, idx) => { %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td><%= item.nip || '-' %></td>
                  <td><%= item.nama || '-' %></td>
                  <td><%= item.jabatan || '-' %></td>
                  <td style="white-space:pre-line;"><%= item.deskripsiTugas || '-' %></td>
                </tr>
              <% }) %>
              <% if (!jadwalPetugasList.length) { %>
                <tr><td colspan="5" class="dapur-empty">Belum ada jadwal petugas pada tanggal ini</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } else if (activeTab === 'distribusi') { %>
        <div class="dapur-filter">
          <form method="GET" action="/kalapas/table/dapur">
            <input type="hidden" name="tab" value="distribusi">
            <div>
              <span class="label">Tanggal Distribusi</span>
              <input type="date" name="tanggal" value="<%= selectedDate %>">
            </div>
            <button type="submit">📅 Tampilkan</button>
            <a href="/kalapas/table/dapur?tab=distribusi" class="reset">↺ Hari Ini</a>
          </form>
          <div class="dapur-meta">
            <div><strong>DISTRIBUSI MAKANAN</strong></div>
            <div>Tanggal aktif: <%= selectedDateLabel %> | Header sesi: Pagi, Siang, Sore</div>
          </div>
        </div>

        <div class="panel-content" style="padding-top:0;">
          <table class="data-table dapur-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Nama Blok</th>
                <th>Pagi (08:00)</th>
                <th>Siang (12:00)</th>
                <th>Sore (16:00)</th>
              </tr>
            </thead>
            <tbody>
              <% distribusiRows.forEach((item, idx) => { %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td style="text-align:left;"><%= item.namaBlok || '-' %></td>
                  <td><%= item.jumlahPagi ?? '-' %></td>
                  <td><%= item.jumlahSiang ?? '-' %></td>
                  <td><%= item.jumlahSore ?? '-' %></td>
                </tr>
              <% }) %>
              <% if (!distribusiRows.length) { %>
                <tr><td colspan="5" class="dapur-empty">Belum ada data distribusi</td></tr>
              <% } %>
            </tbody>
          </table>
          <div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;">
            <% distribusiStatusPerJam.forEach((item) => { %>
              <span style="display:inline-flex;align-items:center;gap:6px;border:1px solid <%= item.complete ? '#86efac' : '#fca5a5' %>;background:<%= item.complete ? '#f0fdf4' : '#fef2f2' %>;color:<%= item.complete ? '#166534' : '#991b1b' %>;border-radius:999px;padding:4px 10px;font-size:12px;font-weight:800;">
                Jam <%= item.jam %> <%= item.complete ? '✓ Lengkap' : '• Belum Lengkap' %>
              </span>
            <% }) %>
          </div>
        </div>
      <% } else if (activeTab === 'permintaan') { %>
        <div class="dapur-filter">
          <form method="GET" action="/kalapas/table/dapur">
            <input type="hidden" name="tab" value="permintaan">
            <div>
              <span class="label">Tanggal</span>
              <input type="date" name="tanggal" value="<%= selectedDate %>">
            </div>
            <button type="submit">📅 Tampilkan</button>
            <a href="/kalapas/table/dapur?tab=permintaan" class="reset">↺ Hari Ini</a>
          </form>
          <div class="dapur-meta">
            <div><strong>PERMINTAAN BAHAN MAKANAN</strong></div>
            <div>Tanggal aktif: <%= selectedDateLabel %> | Template Menu Harian: <%= selectedBamaMenuHari || 'BELUM DISET' %></div>
          </div>
        </div>
        <div class="panel-content" style="padding-top:0;">
          <table class="data-table dapur-table">
            <thead>
              <tr>
                <th>No</th>
                <th>Jenis Bahan Makanan</th>
                <th>Berat Kotor</th>
                <th>Satuan</th>
                <th>Banyaknya</th>
                <th>Keterangan</th>
              </tr>
            </thead>
            <tbody>
              <% bamaMasterList.forEach((item, idx) => { const row = permintaanById?.[item.id] || {}; %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td style="text-align:left;"><%= item.namaBahan || '-' %></td>
                  <td><%= row.beratKotor || '-' %></td>
                  <td><%= row.satuan || item.satuanDefault || '-' %></td>
                  <td><%= row.banyaknya || '-' %></td>
                  <td><%= row.keterangan || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else if (activeTab === 'diterima') { %>
        <div class="dapur-filter">
          <form method="GET" action="/kalapas/table/dapur">
            <input type="hidden" name="tab" value="diterima">
            <div>
              <span class="label">Tanggal</span>
              <input type="date" name="tanggal" value="<%= selectedDate %>">
            </div>
            <button type="submit">📅 Tampilkan</button>
            <a href="/kalapas/table/dapur?tab=diterima" class="reset">↺ Hari Ini</a>
          </form>
          <div class="dapur-meta">
            <div><strong>PENERIMAAN BAHAN MAKANAN</strong></div>
            <div>Tanggal aktif: <%= selectedDateLabel %> | Template Menu Harian: <%= selectedBamaMenuHari || 'BELUM DISET' %></div>
          </div>
        </div>
        <div class="panel-content" style="padding-top:0;">
          <table class="data-table dapur-table">
            <thead>
              <tr>
                <th>No</th>
                <th>Jenis BAMA</th>
                <th>Satuan</th>
                <th>Jumlah Permintaan BAMA</th>
                <th>Jumlah BAMA yang Diterima</th>
                <th>Keterangan</th>
              </tr>
            </thead>
            <tbody>
              <% bamaMasterList.forEach((item, idx) => { const row = diterimaById?.[item.id] || {}; %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td style="text-align:left;"><%= item.namaBahan || '-' %></td>
                  <td><%= row.satuan || item.satuanDefault || '-' %></td>
                  <td><%= row.jumlahPermintaan || '-' %></td>
                  <td><%= row.jumlahDiterima || '-' %></td>
                  <td><%= row.keterangan || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="dapur-filter">
          <form method="GET" action="/kalapas/table/dapur">
            <input type="hidden" name="tab" value="penyimpanan">
            <div>
              <span class="label">Tanggal</span>
              <input type="date" name="tanggal" value="<%= selectedDate %>">
            </div>
            <button type="submit">📅 Tampilkan</button>
            <a href="/kalapas/table/dapur?tab=penyimpanan" class="reset">↺ Hari Ini</a>
          </form>
          <div class="dapur-meta">
            <div><strong>PENYIMPANAN BAHAN MAKANAN</strong></div>
            <div>Tanggal aktif: <%= selectedDateLabel %> | Template Menu Harian: <%= selectedBamaMenuHari || 'BELUM DISET' %></div>
          </div>
        </div>
        <div class="panel-content" style="padding-top:0;">
          <table class="data-table dapur-table">
            <thead>
              <tr>
                <th>No</th>
                <th>Nama Barang</th>
                <th>Satuan</th>
                <th>Barang Masuk</th>
                <th>Barang Keluar</th>
                <th>Barang Sisa</th>
                <th>Keterangan</th>
              </tr>
            </thead>
            <tbody>
              <% bamaMasterList.forEach((item, idx) => { const row = penyimpananById?.[item.id] || {}; %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td style="text-align:left;"><%= item.namaBahan || '-' %></td>
                  <td><%= row.satuan || item.satuanDefault || '-' %></td>
                  <td><%= row.barangMasuk || '-' %></td>
                  <td><%= row.barangKeluar || '-' %></td>
                  <td><%= row.barangSisa || '-' %></td>
                  <td><%= row.keterangan || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    (function () {
      const photos = document.querySelectorAll('.dapur-photo');
      if (!photos.length) return;

      const lightbox = document.createElement('div');
      lightbox.className = 'dapur-photo-lightbox';
      lightbox.innerHTML = '<button type="button" class="close-btn" aria-label="Tutup">×</button><img src="" alt="Preview foto menu">';

      const previewImg = lightbox.querySelector('img');
      const closeBtn = lightbox.querySelector('.close-btn');

      function closeLightbox() {
        lightbox.classList.remove('is-open');
        previewImg.src = '';
      }

      function openLightbox(src, alt) {
        previewImg.src = src;
        previewImg.alt = alt || 'Preview foto menu';
        lightbox.classList.add('is-open');
      }

      photos.forEach((photo) => {
        photo.addEventListener('click', () => {
          const src = photo.getAttribute('src') || '';
          if (!src) return;
          openLightbox(src, photo.getAttribute('alt'));
        });
      });

      closeBtn.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) closeLightbox();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && lightbox.classList.contains('is-open')) {
          closeLightbox();
        }
      });

      document.body.appendChild(lightbox);
    })();
  </script>
  <script src="/js/overlay-guard.js?v=<%= Date.now() %>"></script>
</body>
</html>
