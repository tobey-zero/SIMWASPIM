<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>KRISNA - Tampilan Klinik</title>
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
</head>
<body class="page-klinik">
    <header class="header">
        <div class="header-content">
            <div class="logo-section">
                <div class="logo" data-secret-kalapas="true" style="cursor: pointer;">
                    <img src="/images/Logo.jpeg" alt="Logo" data-secret-kalapas="true" style="width: 100%; height: 100%; object-fit: contain; display: block;">
                </div>
                <div class="header-info">
                    <h2>KETERBUKAAN INFORMASI LAYANAN KESEHATAN</h2>
                    <h3>LAPAS KELAS 1 MEDAN</h3>
                    <p class="address">Jl. Lembaga Pemasyarakatan No.27, Tj. Gusta, Kec. Medan Helvetia, Kota Medan, Sumatera Utara 20125</p>
                    <p class="contact">Phone: (061) 8452195 | Email: lapas1medan27@yahoo.co.id</p>
                </div>
            </div>
            <div class="stats">
                <div class="stat-item">
                    <div class="stat-label">Tenaga Medis</div>
                    <div class="stat-value"><%= clinicSummary.totalTenagaMedis %></div>
                </div>
                <div class="stat-item">
                    <div class="stat-label">JUMLAH WARGA BINAAN SAKIT</div>
                    <div class="stat-value"><%= clinicSummary.totalWbpBerobat %></div>
                </div>

                <div class="stat-item bebas">
                    <div class="stat-label">Tanggal</div>
                    <div class="stat-value"><%= tanggal %></div>
                </div>
            </div>
        </div>
    </header>


    <div class="main-container">
        <div class="left-column">
            <div class="panel panel-clinic-medis">
                <div class="panel-header red">TENAGA MEDIS</div>
                <div class="panel-content">
                    <table>
                        <thead>
                            <tr>
                                <th>NAMA</th>
                                <th>PROFESI</th>
                                <th>STATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% tenagaMedis.forEach(item => { %>
                            <tr>
                                <td><%= item.nama %></td>
                                <td><%= item.profesi %></td>
                                <td><%= item.statusTugas %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="panel panel-clinic-summary">
                <div class="panel-header red">RINGKASAN KESEHATAN WARGA BINAAN</div>
                <div class="panel-content clinic-summary-content">
                    <div class="clinic-summary-tiles">
                        <div class="clinic-summary-tile clinic-summary-tile-highlight">
                            <div class="clinic-summary-tile-title">JUMLAH WARGA BINAAN SAKIT</div>
                            <div class="clinic-summary-tile-value"><%= clinicSummary.totalWbpBerobat %></div>
                        </div>
                        <div class="clinic-summary-tile">
                            <div class="clinic-summary-tile-title">WARGA BINAAN RAWAT JALAN/KLINIK</div>
                            <div class="clinic-summary-tile-value"><%= clinicSummary.rawatJalan %></div>
                        </div>
                        <div class="clinic-summary-tile">
                            <div class="clinic-summary-tile-title">WARGA BINAAN RAWAT INAP RS</div>
                            <div class="clinic-summary-tile-value"><%= clinicSummary.rawatInapAktif %></div>
                        </div>
                        <div class="clinic-summary-tile">
                            <div class="clinic-summary-tile-title">WARGA BINAAN DI BLOK LANSIA</div>
                            <div class="clinic-summary-tile-value"><%= clinicSummary.blokLansia %></div>
                        </div>
                        <div class="clinic-summary-tile clinic-summary-tile-wide">
                            <div class="clinic-summary-tile-title">WARGA BINAAN PENYAKIT KRONIS (TB, PARU, HIV, LAINNYA)</div>
                            <div class="clinic-summary-tile-value"><%= clinicSummary.totalKronis %></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="right-column">
            <div class="panel panel-clinic-berobat">
                <div class="panel-header-with-date">
                    <span class="panel-title">WARGA BINAAN SAKIT</span>
                    <span class="panel-date">Update Harian</span>
                </div>
                <div class="panel-content">
                    <table>
                        <thead>
                            <tr>
                                <th>NO REG</th>
                                <th>NAMA WARGA BINAAN</th>
                                <th>LAYANAN</th>
                                <th>DIAGNOSA</th>
                                <th>BLOK</th>
                                <th>STATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% wbpBerobat.forEach(item => { %>
                            <tr>
                                <td><%= item.noReg %></td>
                                <td><%= item.namaWbp %></td>
                                <td><%= item.layanan %></td>
                                <td><%= item.diagnosa %></td>
                                <td><%= item.blok %></td>
                                <td><%= item.statusPerawatan %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="bottom-panels clinic-bottom-panels">
                <!-- Atas: Jadwal On Call dan Kontrol -->
                <div class="clinic-schedule-stack" style="display: flex; flex-direction: row; gap: 15px; flex: 1; min-height: 0;">
                    <div class="panel sub-panel" style="flex: 1; display:flex; flex-direction:column; min-height:0;">
                        <div class="panel-header red">JADWAL ON CALL PETUGAS</div>
                        <div class="panel-content" style="flex:1; overflow-y:auto;">
                            <table>
                                <thead>
                                    <tr>
                                        <th>HARI</th>
                                        <th>SHIFT</th>
                                        <th>PETUGAS</th>
                                        <th>PROFESI</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% jadwalOnCall.forEach(item => { %>
                                    <tr>
                                        <td><%= item.hari %></td>
                                        <td><%= item.shift %></td>
                                        <td><%= item.petugas %></td>
                                        <td><%= item.profesi %></td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="panel sub-panel" style="flex: 1; display:flex; flex-direction:column; min-height:0;">
                        <div class="panel-header red">JADWAL KONTROL KESEHATAN KE BLOK</div>
                        <div class="panel-content" style="flex:1; overflow-y:auto;">
                            <table>
                                <thead>
                                    <tr>
                                        <th>HARI</th>
                                        <th>WAKTU</th>
                                        <th>BLOK/KAMAR</th>
                                        <th>PETUGAS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% jadwalKontrol.forEach(item => { %>
                                    <tr>
                                        <td><%= item.hari %></td>
                                        <td><%= item.waktu %></td>
                                        <td><%= item.lokasiBlok %></td>
                                        <td><%= item.petugas %></td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Bawah: Antrian Klinik -->
                <div class="panel sub-panel" style="display:flex; flex-direction:column; flex: 1; min-height:0;">
                    <div class="panel-header red">ANTRIAN KLINIK HARI INI</div>
                    <div class="panel-content clinic-summary-content" style="display:flex; flex-direction:row; gap:15px; flex: 1; overflow:hidden; padding: 15px;">
                        <div style="background:#fffbeb; border:2px solid #fbbf24; border-radius:8px; padding:15px; text-align:center; flex:1; display:flex; flex-direction:column; overflow:hidden;">
                            <h3 style="margin:0 0 10px 0; font-size:20px; color:#d97706;">SEDANG DIPANGGIL</h3>
                            <div id="dipanggil-grid" style="display:flex; flex-direction:column; gap:10px; overflow-y:auto; flex:1; align-content:start;">
                                <div style="display:flex; justify-content:center; align-items:center; color:#b45309; height:100%;">Belum ada antrian dipanggil</div>
                            </div>
                        </div>
                        <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:15px; flex: 1.5; display:flex; flex-direction:column; min-height:0;">
                            <h4 style="margin:0 0 10px 0; font-size:18px; color:#334155;">Daftar Antrian Selanjutnya</h4>
                            <div id="antrian-list" style="display:flex; flex-direction:column; gap:8px; overflow-y:auto; flex:1; padding-right:5px;">
                                <!-- List antrian akan dimuat disini -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer">
        <div class="footer-running">
            <div class="footer-running-track">
                <span><%= kataBijak %></span>
            </div>
        </div>
        <div class="footer-bottom" style="display: flex; justify-content: space-between; align-items: center; text-align: left;">
            <p style="flex: 1; max-width: 60%;"><strong>KRISNA</strong> - Tampilan Klinik untuk keterbukaan informasi layanan kesehatan Warga Binaan.</p>
            <p style="text-align: right; flex: 1;">Keterbukaan Informasi Warga Binaan Lapas Kelas I Medan<br>
            Copyright &copy; <%= new Date().getFullYear() %>, by Dimstatons. All Right Reserved</p>
        </div>
    </footer>
    <script>
        (function () {
            document.querySelectorAll('[data-secret-kalapas="true"]').forEach(function (el) {
                el.addEventListener('click', function () {
                    window.location.href = '/kalapas';
                });
            });
        })();
    </script>
    <script>
        window.DISABLE_DATA_WATCHER = true;
    </script>
    <script src="/js/display-mode.js?v=<%= Date.now() %>"></script>
    <script>
        // Audio Activation Overlay (Required by browser policy)
        // Browser security requires a user click to allow speech synthesis.
        // This overlay will only appear ONCE when the TV is turn on. The page will NOT refresh when patients are called.
        const overlay = document.createElement('div');
        overlay.id = 'audio-overlay';
        overlay.style.position = 'fixed';
        overlay.style.top = '0';
        overlay.style.left = '0';
        overlay.style.width = '100vw';
        overlay.style.height = '100vh';
        overlay.style.backgroundColor = 'rgba(0,0,0,0.8)';
        overlay.style.color = 'white';
        overlay.style.display = 'flex';
        overlay.style.flexDirection = 'column';
        overlay.style.alignItems = 'center';
        overlay.style.justifyContent = 'center';
        overlay.style.zIndex = '9999';
        overlay.style.cursor = 'pointer';
        overlay.innerHTML = '<div style="background:white; color:#1e293b; padding:40px; border-radius:12px; text-align:center; box-shadow:0 10px 25px rgba(0,0,0,0.5); border:4px solid #2563eb;"><h1 style="font-size:36px; margin:0 0 10px 0;">🔊 Sistem Suara TV Klinik</h1><p style="font-size:20px; color:#64748b; margin-top:0;">Klik layar ini <b>sekali saja</b> untuk mengaktifkan pemanggil suara.<br><br><small>Halaman ini akan terupdate otomatis <b>tanpa refresh</b> sehingga tombol ini tidak akan muncul lagi.</small></p><button style="background:#2563eb; color:white; border:none; padding:15px 30px; font-size:24px; border-radius:8px; margin-top:20px; cursor:pointer;">Aktifkan Suara</button></div>';
        document.body.appendChild(overlay);
        
        let isAudioUnlocked = false;
        
        const unlockAudio = () => {
             if (isAudioUnlocked) return;
             isAudioUnlocked = true;
             console.log("Audio unlocked by user interaction.");
             window.speechSynthesis.speak(new SpeechSynthesisUtterance('Suara aktif'));
             overlay.style.display = 'none';
             document.removeEventListener('click', unlockAudio);
             document.removeEventListener('touchstart', unlockAudio);
        };
        
        overlay.addEventListener('click', unlockAudio);
        document.addEventListener('click', unlockAudio);
        document.addEventListener('touchstart', unlockAudio);

        // Start auto-scroll after a short delay to ensure rendering
        function startAutoScroll() {
            ['dipanggil-grid', 'antrian-list'].forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                
                // Hide scrollbar aesthetically
                el.style.scrollbarWidth = 'none';
                el.style.msOverflowStyle = 'none';
                
                let isPaused = false;
                setInterval(() => {
                    if (isPaused || el.scrollHeight <= el.clientHeight) return;
                    
                    let prevScroll = el.scrollTop;
                    el.scrollTop += 1;
                    
                    if (el.scrollTop === prevScroll) {
                        isPaused = true;
                        setTimeout(() => {
                            el.scrollTop = 0;
                            setTimeout(() => {
                                isPaused = false;
                            }, 2000);
                        }, 3000);
                    }
                }, 40);
            });
        }
        
        // Start auto-scroll after a short delay to ensure rendering
        setTimeout(startAutoScroll, 1000);

        // Memuat daftar antrian
        function loadAntrian() {
            fetch('/api/klinik/antrian-list')
                .then(res => res.json())
                .then(data => {
                    const listContainer = document.getElementById('antrian-list');
                    listContainer.innerHTML = '';
                    
                    const dipanggilList = data.filter(item => item.status === 'dipanggil');
                    dipanggilList.sort((a, b) => new Date(b.called_at || 0) - new Date(a.called_at || 0));
                    
                    const dipanggilGrid = document.getElementById('dipanggil-grid');
                    dipanggilGrid.innerHTML = '';
                    
                    if (dipanggilList.length > 0) {
                        // Group by tujuan to display the most recently called per room
                        const roomMap = new Map();
                        dipanggilList.forEach(item => {
                            const tujuan = item.tujuan || 'Ruang Pemeriksaan Dokter Umum';
                            if (!roomMap.has(tujuan)) {
                                roomMap.set(tujuan, item);
                            }
                        });
                        
                        roomMap.forEach((item, tujuan) => {
                            dipanggilGrid.innerHTML += `
                                <div style="background:white; border:1px solid #fcd34d; border-radius:6px; padding:10px 15px; display:flex; justify-content:space-between; align-items:center;">
                                    <div style="display:flex; flex-direction:column; text-align:left;">
                                        <div style="font-size:12px; font-weight:bold; color:#64748b; margin-bottom:4px; text-transform:uppercase;">${tujuan}</div>
                                        <div style="font-size:22px; font-weight:800; color:#1f2937; line-height:1;">${item.nama_pasien}</div>
                                    </div>
                                    <div style="font-size:32px; font-weight:900; color:#b45309;">No. ${item.no_antrian}</div>
                                </div>
                            `;
                        });
                    } else {
                        dipanggilGrid.innerHTML = '<div style="display:flex; justify-content:center; align-items:center; color:#b45309; height:100%;">Belum ada antrian dipanggil</div>';
                    }

                    data.forEach(item => {
                        if (item.status === 'menunggu') {
                            listContainer.innerHTML += `
                                <div style="display:flex; justify-content:space-between; align-items:center; padding:8px; background:white; border:1px solid #cbd5e1; border-radius:4px;">
                                    <div>
                                        <div style="font-weight:bold; font-size:18px;">No. ${item.no_antrian}</div>
                                        <div style="font-size:12px; color:#64748b;">${item.tujuan || 'Ruang Pemeriksaan Dokter Umum'}</div>
                                    </div>
                                    <span style="font-size:18px; text-align:right;">${item.nama_pasien}</span>
                                </div>
                            `;
                        }
                    });

                    if (listContainer.innerHTML === '') {
                        listContainer.innerHTML = '<div style="text-align:center; padding:10px; color:#64748b;">Belum ada antrian menunggu</div>';
                    }
                });
        }
        
        loadAntrian();

        // SSE Connection
        const evtSource = new EventSource("/api/klinik/antrian-stream");
        evtSource.onmessage = function(event) {
            const msg = JSON.parse(event.data);
            if (msg.type === 'UPDATE') {
                loadAntrian();
            } else if (msg.type === 'CALL') {
                loadAntrian();
                // Play sound
                playCallSound(msg.data.no_antrian, msg.data.nama_pasien, msg.data.tujuan);
            }
        };

        let voiceSynth = window.speechSynthesis;
        function playCallSound(no_antrian, nama_pasien, tujuan) {
            console.log(`[Audio Event] Attempting to play sound for: No.${no_antrian} ${nama_pasien} -> ${tujuan}`);
            console.log(`[Audio Event] isAudioUnlocked: ${isAudioUnlocked}, window.speechSynthesis supported: ${!!voiceSynth}`);
            
            if (!voiceSynth) {
                console.warn("[Audio Event] window.speechSynthesis is not available in this browser.");
                return;
            }
            
            if (!isAudioUnlocked) {
                 console.warn("[Audio Event] Audio is NOT UNLOCKED! User needs to click the screen first. Text-to-speech might fail.");
                 // We will still try to speak, but browsers will likely block it.
            }

            const target = tujuan || 'ruang periksa';
            const text = `Nomor antrian. ${no_antrian}. atas nama. ${nama_pasien}. silahkan menuju ${target}.`;
            const utterThis = new SpeechSynthesisUtterance(text);
            utterThis.lang = 'id-ID';
            utterThis.rate = 0.9;
            
            utterThis.onstart = function () {
                console.log("[Audio Event] Speech started playing successfully.");
            };
            utterThis.onerror = function (event) {
                console.error("[Audio Event] Speech synthesis error:", event.error);
            };
            
            console.log(`[Audio Event] Enqueueing speech text: "${text}"`);
            voiceSynth.speak(utterThis);
        }
    </script>
</body>
</html>
