<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> - Kalapas</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
  <style>
    .piket-wrap { padding: 14px 15px; }
    .piket-toolbar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 10px;
    }
    .piket-toolbar a, .piket-toolbar button {
      text-decoration: none;
      color: #fff;
      background: #1a4bb8;
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 6px;
      padding: 7px 11px;
      font-size: 12px;
      font-weight: bold;
      cursor: pointer;
    }
    .piket-submenu {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .piket-submenu a {
      text-decoration: none;
      border: 1px solid #93c5fd;
      color: #1e3a8a;
      background: #eff6ff;
      border-radius: 6px;
      padding: 7px 11px;
      font-size: 12px;
      font-weight: bold;
    }
    .piket-submenu a.active {
      color: #fff;
      background: #1a4bb8;
      border-color: rgba(255,255,255,.3);
    }
    .piket-filter {
      display: flex;
      gap: 8px;
      align-items: end;
      flex-wrap: wrap;
      margin-left: auto;
    }
    .piket-filter label {
      font-size: 11px;
      color: #1e293b;
      font-weight: 700;
      display: block;
      margin-bottom: 3px;
    }
    .piket-filter select {
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      padding: 7px 9px;
      font-size: 12px;
      font-weight: 700;
      color: #0f172a;
      background: #fff;
    }

    .piket-board {
      border: 3px solid #111827;
      background: #f8fafc;
      overflow-x: auto;
    }
    .piket-table {
      border-collapse: collapse;
      min-width: 1400px;
      width: 100%;
      table-layout: fixed;
    }
    .piket-table col.col-no {
      width: 60px;
      min-width: 60px;
      max-width: 60px;
    }
    .piket-table col.col-regu {
      width: 240px;
      min-width: 240px;
      max-width: 240px;
    }
    .piket-table th,
    .piket-table td {
      border: 1px solid #111827;
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      color: #0f172a;
      padding: 5px 4px;
      white-space: nowrap;
    }
    .piket-table th {
      background: #e5e7eb;
    }
    .piket-table .title-row th {
      background: #f3f4f6;
      font-size: 14px;
      letter-spacing: .3px;
    }
    .piket-table .day-number.red,
    .piket-table .day-name.red {
      color: #dc2626;
    }
    .piket-table .regu-cell {
      min-width: 240px;
      font-size: 14px;
      letter-spacing: 1px;
      background: #f9fafb;
      white-space: nowrap;
      overflow: hidden;
    }
    .piket-table .shift-cell {
      width: 32px;
      min-width: 32px;
      max-width: 32px;
      height: 40px;
      background: #ffffff;
      font-size: 14px;
      font-weight: 500;
      font-family: "Times New Roman", serif;
      overflow: hidden;
    }
    .piket-table .shift-cell.weekend {
      background: #f3f4f6;
    }
    .piket-notes {
      margin-top: 12px;
      border: 2px solid #111827;
      border-top: 0;
      background: #ffffff;
      padding: 10px 12px;
      font-size: 13px;
      color: #111827;
      font-weight: 600;
      line-height: 1.5;
    }
    .piket-notes h4 {
      margin: 0 0 6px;
      font-size: 16px;
      letter-spacing: .3px;
    }
    .piket-notes ol {
      margin: 0;
      padding-left: 20px;
    }
    .piket-notes li {
      margin-bottom: 2px;
    }
    .piket-members { margin-top: 12px; }
    .piket-member-block { margin-bottom: 10px; border: 2px solid #111827; background: #fff; overflow-x: auto; }
    .piket-member-title { padding: 6px 8px; font-size: 13px; font-weight: 700; color: #0f172a; border-bottom: 1px solid #111827; background: #f8fafc; }
    .piket-member-table { width: 100%; min-width: 1200px; border-collapse: collapse; table-layout: fixed; }
    .piket-member-table th, .piket-member-table td { border: 1px solid #111827; text-align: center; padding: 3px 2px; font-size: 11px; color: #0f172a; font-weight: 700; white-space: nowrap; }
    .piket-member-table th { background: #e5e7eb; }
    .piket-member-table .day-number.red, .piket-member-table .day-name.red { color: #dc2626; }
    .piket-member-table .col-no { width: 28px; min-width: 28px; max-width: 28px; }
    .piket-member-table .col-nama { width: 200px; min-width: 200px; max-width: 200px; text-align: left; padding-left: 6px; }
    .piket-member-table .col-gol { width: 50px; min-width: 50px; max-width: 50px; }
    .piket-member-table .col-jabatan { width: 82px; min-width: 82px; max-width: 82px; }
    .piket-member-table .col-shift { width: 28px; min-width: 28px; max-width: 28px; font-size: 10px; }
  </style>
</head>
<body class="page-umum">
  <header class="header">
    <div class="header-content">
      <div class="logo-section">
        <div class="logo kalapas-logo">
          <img src="/images/simwaspim.jpeg" alt="Logo SIMWASPIM" class="kalapas-logo-img">
        </div>
        <div class="header-info">
          <h2>KAMTIB</h2>
          <h3>PIKET JAGA</h3>
          <p class="address"><%= subtitle %></p>
        </div>
      </div>
    </div>
  </header>

  <div class="piket-wrap">
    <div class="piket-toolbar">
      <a href="<%= backUrl %>">⬅ Kembali ke Kamtib</a>
      <form method="GET" action="/kalapas/table/piket-jaga" class="piket-filter">
        <div>
          <label>Bulan</label>
          <select name="month">
            <% monthOptions.forEach(opt => { %>
              <option value="<%= opt.value %>" <%= opt.value === selectedMonth ? 'selected' : '' %>><%= opt.label %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Tahun</label>
          <select name="year">
            <% yearOptions.forEach(year => { %>
              <option value="<%= year %>" <%= String(year) === String(selectedYear) ? 'selected' : '' %>><%= year %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit">Terapkan</button>
      </form>
    </div>

    <div class="piket-submenu">
      <a href="/kalapas/table/kamtib" class="<%= kamtibSubmenu && kamtibSubmenu.active === 'ringkasan' ? 'active' : '' %>">🛡 Ringkasan</a>
      <a href="/kalapas/table/razia-jadwal" class="<%= kamtibSubmenu && kamtibSubmenu.active === 'razia-jadwal' ? 'active' : '' %>">📅 Giat Razia</a>
      <a href="/kalapas/table/razia-barang-bukti" class="<%= kamtibSubmenu && kamtibSubmenu.active === 'razia-barang-bukti' ? 'active' : '' %>">📦 Barang Bukti</a>
      <a href="/kalapas/table/pengawalan" class="<%= kamtibSubmenu && kamtibSubmenu.active === 'pengawalan' ? 'active' : '' %>">🚔 Pengawalan</a>
      <a href="/kalapas/table/strapsel" class="<%= kamtibSubmenu && kamtibSubmenu.active === 'strapsel' ? 'active' : '' %>">⛓ Strapsel</a>
      <a href="/kalapas/table/register-f" class="<%= kamtibSubmenu && kamtibSubmenu.active === 'register-f' ? 'active' : '' %>">📘 Register F</a>
      <a href="/kalapas/table/piket-jaga?month=<%= encodeURIComponent(selectedMonth) %>&year=<%= encodeURIComponent(selectedYear) %>" class="<%= kamtibSubmenu && kamtibSubmenu.active === 'piket-jaga' ? 'active' : '' %>">🧷 Piket Jaga</a>
      <a href="/kalapas/table/pengaduan?month=<%= encodeURIComponent(selectedMonth) %>&year=<%= encodeURIComponent(selectedYear) %>" class="<%= kamtibSubmenu && kamtibSubmenu.active === 'pengaduan' ? 'active' : '' %>">📢 Pengaduan</a>
    </div>

    <div class="piket-board">
      <table class="piket-table">
        <colgroup>
          <col class="col-no">
          <col class="col-regu">
          <% days.forEach(() => { %>
            <col>
          <% }) %>
        </colgroup>
        <thead>
          <tr class="title-row">
            <th colspan="<%= days.length + 2 %>">TANGGAL/ HARI PELAKSANAAN TUGAS</th>
          </tr>
          <tr>
            <th rowspan="2">NO</th>
            <th rowspan="2">REGU PENGAMANAN</th>
            <% days.forEach(day => { %>
              <th class="day-number <%= day.isWeekend ? 'red' : '' %>"><%= day.day %></th>
            <% }) %>
          </tr>
          <tr>
            <% days.forEach(day => { %>
              <th class="day-name <%= day.isWeekend ? 'red' : '' %>"><%= day.dayCode %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% reguNames.forEach((reguName, reguIndex) => { %>
            <tr>
              <td><%= reguIndex + 1 %></td>
              <td class="regu-cell"><%= reguName %></td>
              <% days.forEach((day, dayIndex) => { %>
                <td class="shift-cell <%= day.isWeekend ? 'weekend' : '' %>"><%= schedules[reguIndex][dayIndex] || '' %></td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="piket-members">
      <% reguNames.forEach((reguName, reguIndex) => { %>
        <% const members = reguMembers[reguIndex] || []; %>
        <div class="piket-member-block">
          <div class="piket-member-title"><%= reguName %> – DAFTAR PETUGAS</div>
          <table class="piket-member-table">
            <thead>
              <tr>
                <th class="col-no" rowspan="2">NO</th>
                <th class="col-nama" rowspan="2">NAMA PETUGAS</th>
                <th class="col-gol" rowspan="2">GOL</th>
                <th class="col-jabatan" rowspan="2">JABATAN</th>
                <% days.forEach(day => { %>
                  <th class="day-number <%= day.isWeekend ? 'red' : '' %>"><%= day.day %></th>
                <% }) %>
              </tr>
              <tr>
                <% days.forEach(day => { %>
                  <th class="day-name <%= day.isWeekend ? 'red' : '' %>"><%= day.dayCode %></th>
                <% }) %>
              </tr>
            </thead>
            <tbody>
              <% if (members.length) { %>
                <% members.forEach((member, memberIndex) => { %>
                  <tr>
                    <td class="col-no"><%= memberIndex + 1 %></td>
                    <td class="col-nama"><%= member.nama %></td>
                    <td class="col-gol"><%= member.gol || '-' %></td>
                    <td class="col-jabatan"><%= member.jabatan || 'ANGGOTA' %></td>
                    <% days.forEach((_day, dayIndex) => { %>
                      <td class="col-shift"><%= schedules[reguIndex][dayIndex] || '' %></td>
                    <% }) %>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="<%= days.length + 4 %>" style="font-size:12px;color:#64748b;padding:10px;">Belum ada daftar petugas untuk regu ini.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% }) %>
    </div>

    <div class="piket-notes">
      <h4>CATATAN :</h4>
      <ol>
        <% piketNotes.forEach(note => { %>
          <li><%= note %></li>
        <% }) %>
      </ol>
    </div>
  </div>
</body>
</html>
