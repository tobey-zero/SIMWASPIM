<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Papan Keadaan Isi Lapas</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
  <style>
    .logo.kalapas-logo { background-color: transparent; padding: 0; }
    .kalapas-logo-img { width: 86px; height: 86px; object-fit: contain; display: block; }

    .board-wrap { padding: 12px 15px 16px; }
    .board-title {
      text-align: center;
      margin: 0 0 10px;
      font-size: 24px;
      letter-spacing: 1.2px;
      color: #0f172a;
      font-weight: 900;
    }
    .board-subtitle {
      text-align: center;
      margin: 0 0 14px;
      font-size: 13px;
      color: #475569;
      font-weight: 700;
    }
    .board-toolbar { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px; }
    .board-toolbar a {
      text-decoration:none;
      color:#fff;
      background:#1a4bb8;
      border:1px solid rgba(255,255,255,.35);
      border-radius:6px;
      padding:7px 11px;
      font-size:12px;
      font-weight:bold;
    }
    .board-submenu {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
    .board-submenu a {
      text-decoration: none;
      border: 1px solid #93c5fd;
      color: #1e3a8a;
      background: #eff6ff;
      border-radius: 6px;
      padding: 7px 11px;
      font-size: 12px;
      font-weight: bold;
    }
    .board-submenu a.active {
      color: #fff;
      background: #1a4bb8;
      border-color: rgba(255,255,255,.3);
    }

    .board-grid {
      display:grid;
      grid-template-columns: 2fr 1fr;
      gap:12px;
    }

    .board-panel {
      background:#fff;
      border:1px solid #cbd5e1;
      border-radius:8px;
      overflow:hidden;
    }
    .board-panel.full-span { grid-column: 1 / -1; }

    .board-panel h4 {
      margin:0;
      padding:8px 10px;
      background:#dbeafe;
      color:#1e3a8a;
      font-size:12px;
      letter-spacing:.4px;
      font-weight:800;
      text-transform:uppercase;
      border-bottom:1px solid #bfdbfe;
    }

    .wna-pie-wrap {
      display: grid;
      grid-template-columns: 170px 1fr;
      gap: 14px;
      align-items: center;
      padding: 12px;
    }
    .wna-pie-chart {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      border: 1px solid #cbd5e1;
      margin: 0 auto;
    }
    .wna-pie-legend {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 6px;
      font-size: 12px;
      color: #0f172a;
    }
    .wna-pie-legend li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      border-bottom: 1px dashed #dbeafe;
      padding-bottom: 4px;
    }
    .wna-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 6px;
    }
    .wna-label {
      display: inline-flex;
      align-items: center;
      min-width: 0;
    }
    .wna-empty {
      padding: 12px;
      font-size: 12px;
      color: #64748b;
      font-weight: 700;
      text-align: center;
    }

    .board-table { width:100%; border-collapse:collapse; }
    .board-table th, .board-table td {
      border:1px solid #cbd5e1;
      padding:6px 7px;
      font-size:11px;
      color:#0f172a;
      text-align:center;
      white-space:nowrap;
    }
    .board-table th { background:#eff6ff; font-weight:800; }
    .left { text-align:left !important; }
    .total-row td { font-weight:800; background:#f1f5f9; }

    .split-grid {
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:10px;
      padding:10px;
    }

    .mini-note {
      margin: 10px;
      padding: 8px;
      border:1px dashed #bfdbfe;
      border-radius:7px;
      color:#334155;
      font-size:11px;
      background:#f8fafc;
      text-align:center;
      font-weight:700;
    }

    @media (max-width: 1100px) {
      .board-grid { grid-template-columns: 1fr; }
      .split-grid { grid-template-columns: 1fr; }
      .wna-pie-wrap { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body class="page-umum">
  <header class="header">
    <div class="header-content">
      <div class="logo-section">
        <div class="logo kalapas-logo">
          <img src="/images/simwaspim.jpeg" alt="Logo SIMWASPIM" class="kalapas-logo-img">
        </div>
        <div class="header-info">
          <h2>SIMWASPIM – KETERBUKAAN INFORMASI LAPAS</h2>
          <h3>PAPAN KEADAAN ISI LAPAS</h3>
          <p class="address"><%= tanggal %></p>
        </div>
      </div>
    </div>
  </header>

  <div class="board-wrap">
    <h1 class="board-title">KEADAAN ISI LEMBAGA PEMASYARAKATAN KELAS I MEDAN</h1>
    <p class="board-subtitle">Format awal mengikuti papan fisik (dapat disempurnakan sesuai kebutuhan berikutnya)</p>

    <div class="board-toolbar">
      <a href="/kalapas">⬅ Kembali Dashboard Kalapas</a>
      <a href="/admin/papan-isi" target="_blank">⚙️ Kelola Data Papan</a>
    </div>

    <div class="board-submenu">
      <a href="/kalapas/table/kamar-blok" class="<%= pengamananActiveTab === 'kamar-blok' ? 'active' : '' %>">🏢 Kamar / Blok</a>
      <a href="/kalapas/papan-isi" class="<%= pengamananActiveTab === 'papan-isi' ? 'active' : '' %>">📋 Papan Isi</a>
      <a href="/kalapas/table/luar-tembok" class="<%= pengamananActiveTab === 'luar-tembok' ? 'active' : '' %>">🚶 WBP Luar Tembok</a>
    </div>

    <div class="board-grid">
      <div class="board-panel">
        <h4>Registrasi Warga Binaan (Format Papan Fisik)</h4>
        <table class="board-table">
          <thead>
            <tr>
              <th rowspan="2">NO</th>
              <th rowspan="2">BLOK</th>
              <th rowspan="2">REGISTRASI</th>
              <th colspan="3">WARGA NEGARA INDONESIA</th>
              <th colspan="3">WARGA NEGARA ASING</th>
              <th rowspan="2">JUMLAH</th>
            </tr>
            <tr>
              <th>ISI</th><th>TAMBAH</th><th>KURANG</th>
              <th>ISI</th><th>TAMBAH</th><th>KURANG</th>
            </tr>
          </thead>
          <tbody>
            <% for (const item of registrasiHunian) { %>
            <% const jumlah = (Number(item.wniIsi) || 0) + (Number(item.wniTambah) || 0) + (Number(item.wnaIsi) || 0) + (Number(item.wnaTambah) || 0); %>
            <tr>
              <td><%= item.noUrut %></td>
              <td><strong><%= item.blok %></strong></td>
              <td class="left"><%= item.registrasi %></td>
              <td><%= item.wniIsi || '-' %></td>
              <td><%= item.wniTambah || '-' %></td>
              <td><%= item.wniKurang || '-' %></td>
              <td><%= item.wnaIsi || '-' %></td>
              <td><%= item.wnaTambah || '-' %></td>
              <td><%= item.wnaKurang || '-' %></td>
              <td><%= jumlah || '-' %></td>
            </tr>
            <% } %>
            <% if (!registrasiHunian.length) { %>
            <tr><td colspan="10">Belum ada data registrasi hunian</td></tr>
            <% } %>
            <% if (registrasiHunian.length) { %>
            <tr class="total-row">
              <td colspan="3" class="left">JUMLAH</td>
              <td><%= boardSummary.totalRegistrasiWniIsi %></td>
              <td><%= boardSummary.totalRegistrasiWniTambah %></td>
              <td><%= boardSummary.totalRegistrasiWniKurang %></td>
              <td><%= boardSummary.totalRegistrasiWnaIsi %></td>
              <td><%= boardSummary.totalRegistrasiWnaTambah %></td>
              <td><%= boardSummary.totalRegistrasiWnaKurang %></td>
              <td><%= boardSummary.totalRegistrasiJumlah %></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="board-panel">
        <h4>Warga Negara Asing</h4>
        <table class="board-table">
          <thead><tr><th>Asal Negara</th><th>Jumlah</th></tr></thead>
          <tbody>
            <% for (const item of wnaNegaraRekap) { %>
            <tr>
              <td class="left"><%= item.asalNegara || '-' %></td>
              <td><%= item.jumlah || 0 %></td>
            </tr>
            <% } %>
            <% if (!wnaNegaraRekap.length) { %>
            <tr><td colspan="2">Belum ada data WNA</td></tr>
            <% } %>
            <% if (wnaNegaraRekap.length) { %>
            <tr class="total-row">
              <td class="left">Jumlah</td>
              <td><%= boardSummary.totalWnaNegara %></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="board-panel">
        <h4>Jenis Tindak Pidana</h4>
        <div class="split-grid">
          <div>
            <table class="board-table">
              <thead><tr><th colspan="2">Pidana Khusus</th></tr></thead>
              <tbody>
                <% pidanaKhusus.forEach(item => { %>
                <tr><td class="left"><%= item.jenis %></td><td><%= item.jumlah %></td></tr>
                <% }) %>
                <tr class="total-row"><td class="left">Jumlah</td><td><%= boardSummary.totalPidanaKhusus %></td></tr>
              </tbody>
            </table>
          </div>
          <div>
            <table class="board-table">
              <thead><tr><th colspan="2">Pidana Umum</th></tr></thead>
              <tbody>
                <% pidanaUmum.forEach(item => { %>
                <tr><td class="left"><%= item.jenis %></td><td><%= item.jumlah %></td></tr>
                <% }) %>
                <tr class="total-row"><td class="left">Jumlah</td><td><%= boardSummary.totalPidanaUmum %></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="board-panel">
        <h4>Jumlah WBP Berdasarkan Blok Hunian</h4>
        <table class="board-table">
          <thead><tr><th>Blok</th><th>Kapasitas</th><th>Isi</th></tr></thead>
          <tbody>
            <% housingBlocks.forEach(block => { %>
            <tr>
              <td class="left"><%= block.namaBlock %></td>
              <td><%= block.totalKapasitas %></td>
              <td><%= block.totalPenghuni %></td>
            </tr>
            <% }) %>
            <tr class="total-row">
              <td class="left">Jumlah</td>
              <td><%= kapasitas %></td>
              <td><%= totalPenghuni %></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="board-panel">
        <h4>WBP di Luar Lapas</h4>
        <table class="board-table">
          <thead>
            <tr>
              <th rowspan="2">Status</th>
              <th colspan="2">WNI</th>
              <th colspan="2">WNA</th>
              <th rowspan="2">Jumlah</th>
              <th rowspan="2">Keterangan</th>
            </tr>
            <tr>
              <th>Keluar</th><th>Masuk</th><th>Keluar</th><th>Masuk</th>
            </tr>
          </thead>
          <tbody>
            <% let totalWniKeluar = 0; %>
            <% let totalWniMasuk = 0; %>
            <% let totalWnaKeluar = 0; %>
            <% let totalWnaMasuk = 0; %>
            <% for (const item of luarTembok) { %>
            <% const rowTotal = (Number(item.wniKeluar) || 0) + (Number(item.wniMasuk) || 0) + (Number(item.wnaKeluar) || 0) + (Number(item.wnaMasuk) || 0); %>
            <% totalWniKeluar += Number(item.wniKeluar) || 0; %>
            <% totalWniMasuk += Number(item.wniMasuk) || 0; %>
            <% totalWnaKeluar += Number(item.wnaKeluar) || 0; %>
            <% totalWnaMasuk += Number(item.wnaMasuk) || 0; %>
            <tr>
              <td class="left"><%= item.status %></td>
              <td><%= item.wniKeluar %></td>
              <td><%= item.wniMasuk %></td>
              <td><%= item.wnaKeluar %></td>
              <td><%= item.wnaMasuk %></td>
              <td><%= rowTotal %></td>
              <td class="left"><%= item.keterangan || '-' %></td>
            </tr>
            <% } %>
            <tr class="total-row">
              <td class="left">Jumlah</td>
              <td><%= totalWniKeluar %></td>
              <td><%= totalWniMasuk %></td>
              <td><%= totalWnaKeluar %></td>
              <td><%= totalWnaMasuk %></td>
              <td><%= boardSummary.totalLuarTembok %></td>
              <td>-</td>
            </tr>
          </tbody>
        </table>
      </div>


      <div class="board-panel">
        <h4>Jumlah WBP Berdasarkan Agama</h4>
        <table class="board-table">
          <thead><tr><th>Agama</th><th>WNI</th><th>WNA</th><th>Jumlah</th></tr></thead>
          <tbody>
            <% let totalAgamaWni = 0; %>
            <% let totalAgamaWna = 0; %>
            <% for (const item of agama) { %>
            <% const rowTotal = (Number(item.wni) || 0) + (Number(item.wna) || 0); %>
            <% totalAgamaWni += Number(item.wni) || 0; %>
            <% totalAgamaWna += Number(item.wna) || 0; %>
            <tr>
              <td class="left"><%= item.agama %></td>
              <td><%= item.wni %></td>
              <td><%= item.wna %></td>
              <td><%= rowTotal %></td>
            </tr>
            <% } %>
            <tr class="total-row"><td class="left">Jumlah</td><td><%= totalAgamaWni %></td><td><%= totalAgamaWna %></td><td><%= boardSummary.totalAgama %></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mini-note">Data pada halaman ini bersifat fleksibel dan dapat disesuaikan lagi agar semakin mirip papan manual.</div>
  </div>
  <script>
    (function () {
      const pieChart = document.querySelector('.wna-pie-chart[data-bg]');
      if (pieChart) {
        const bg = pieChart.getAttribute('data-bg') || '';
        pieChart.style.background = bg;
      }
      const dots = document.querySelectorAll('.wna-dot[data-color]');
      dots.forEach(dot => {
        dot.style.background = dot.getAttribute('data-color') || '#94a3b8';
      });
    })();
  </script>
</body>
</html>
