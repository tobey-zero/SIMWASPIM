        <div class="card-header"><h3>Daftar Pemasaran Hasil (<%= pemasaranList.length %> data)</h3></div>
        <div class="card-body" style="border-bottom:1px solid rgba(255,255,255,.06);">
          <form method="GET" action="/admin/giiatja" class="form-grid col-4">
            <div class="form-group">
              <label>Filter Bulan</label>
              <select name="pemasaran_bulan">
                <option value="SEMUA">Semua Bulan</option>
                <% pemasaranMonthOptions.forEach((month) => { %>
                  <option value="<%= month %>" <%= selectedPemasaranMonth === month ? 'selected' : '' %>><%= month %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>Filter Tahun</label>
              <select name="pemasaran_tahun">
                <option value="SEMUA">Semua Tahun</option>
                <% pemasaranYearOptions.forEach((year) => { %>
                  <option value="<%= year %>" <%= selectedPemasaranYear === year ? 'selected' : '' %>><%= year %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="display:flex;align-items:flex-end;gap:8px;">
              <button type="submit" class="btn btn-primary btn-sm">🔎 Terapkan</button>
              <a href="/admin/giiatja?menu=pemasaran" class="btn btn-secondary btn-sm">Reset</a>
            </div>
            <input type="hidden" name="menu" value="pemasaran">
          </form>
        </div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>No</th><th>Tanggal</th><th>Kegiatan</th><th>Hasil Kerja</th><th>Pemasaran Hasil Kerja</th><th>Jumlah Income</th><th>Periode</th><th>Aksi</th></tr></thead>
              <tbody>
                <% pemasaranList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.tanggal || '-' %></td>
                  <td><%= item.kegiatan || '-' %></td>
                  <td><%= item.hasil_kerja || '-' %></td>
                  <td><%= item.pemasaran_hasil_kerja || '-' %></td>
                  <td><%= item.jumlah_income || '-' %></td>
                  <td><%= ((item.periode_bulan || '-') + ' ' + (item.periode_tahun || '-')).trim() %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?menu=pemasaran&editPemasaran=<%= item.id %>&pemasaran_bulan=<%= encodeURIComponent(selectedPemasaranMonth || 'SEMUA') %>&pemasaran_tahun=<%= encodeURIComponent(selectedPemasaranYear || 'SEMUA') %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/pemasaran/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <input type="hidden" name="pemasaran_bulan" value="<%= selectedPemasaranMonth || 'SEMUA' %>">
                        <input type="hidden" name="pemasaran_tahun" value="<%= selectedPemasaranYear || 'SEMUA' %>">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!pemasaranList.length) { %><tr><td colspan="8" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <% if (editPremi) { %>
      <div class="edit-panel" <%- isMenu('premi') ? '' : 'style="display:none;"' %>>
        <h4>✏️ Edit Premi (ID: <%= editPremi.id %>)</h4>
        <form method="POST" action="/admin/giiatja/premi/<%= editPremi.id %>/update">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="<%= editPremi.sort_order || 1 %>"></div>
            <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi" value="<%= editPremi.no_registrasi || '' %>"></div>
            <div class="form-group"><label>Nama WBP</label><input type="text" name="nama_wbp" value="<%= editPremi.nama_wbp || '' %>" required></div>
            <div class="form-group">
              <label>Periode Bulan</label>
              <select name="periode_bulan" required>
                <option value="">Pilih Bulan</option>
                <% ['JANUARI','FEBRUARI','MARET','APRIL','MEI','JUNI','JULI','AGUSTUS','SEPTEMBER','OKTOBER','NOVEMBER','DESEMBER'].forEach((m) => { %>
                  <option value="<%= m %>" <%= (String(editPremi.periode_bulan || '').toUpperCase() === m) ? 'selected' : '' %>><%= m %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group"><label>Periode Tahun</label><input type="number" name="periode_tahun" min="2000" max="2100" value="<%= editPremi.periode_tahun || new Date().getFullYear() %>" required></div>
            <div class="form-group"><label>Jenis Kegiatan</label><input type="text" name="jenis_kegiatan" value="<%= editPremi.jenis_kegiatan || '' %>"></div>
            <div class="form-group"><label>Premi yang Didapat</label><input type="text" name="premi_didapat" value="<%= editPremi.premi_didapat || '' %>"></div>
            <div class="form-group"><label>Keterangan</label><input type="text" name="keterangan" value="<%= editPremi.keterangan || '' %>"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card" <%- isMenu('premi') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>Daftar Premi WBP (<%= premiList.length %> data)</h3></div>
        <div class="card-body" style="border-bottom:1px solid rgba(255,255,255,.06);">
          <form method="GET" action="/admin/giiatja" class="form-grid col-4">
            <div class="form-group"><label>Pencarian Premi</label><input type="text" name="premi_search" value="<%= premiSearch || '' %>" placeholder="Cari nama, kegiatan, premi..."></div>
            <div class="form-group">
              <label>Filter Bulan</label>
              <select name="premi_bulan">
                <option value="SEMUA">Semua Bulan</option>
                <% premiMonthOptions.forEach((month) => { %>
                  <option value="<%= month %>" <%= selectedPremiMonth === month ? 'selected' : '' %>><%= month %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>Filter Tahun</label>
              <select name="premi_tahun">
                <option value="SEMUA">Semua Tahun</option>
                <% premiYearOptions.forEach((year) => { %>
                  <option value="<%= year %>" <%= selectedPremiYear === year ? 'selected' : '' %>><%= year %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="display:flex;align-items:flex-end;gap:8px;">
              <button type="submit" class="btn btn-primary btn-sm">🔎 Terapkan</button>
              <a href="/admin/giiatja" class="btn btn-secondary btn-sm">Reset</a>
            </div>
            <input type="hidden" name="pnbp_tahun" value="<%= selectedPnbpYear || '' %>">
          </form>
        </div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>No</th><th>No Registrasi</th><th>Nama WBP</th><th>Periode</th><th>Jenis Kegiatan</th><th>Premi</th><th>Keterangan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% premiList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.no_registrasi || '-' %></td>
                  <td><%= item.nama_wbp || '-' %></td>
                  <td><%= ((item.periode_bulan || '-') + ' ' + (item.periode_tahun || '-')).trim() %></td>
                  <td><%= item.jenis_kegiatan || '-' %></td>
                  <td><%= item.premi_didapat || '-' %></td>
                  <td><%= item.keterangan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?editPremi=<%= item.id %>&premi_search=<%= encodeURIComponent(premiSearch || '') %>&premi_bulan=<%= encodeURIComponent(selectedPremiMonth || 'SEMUA') %>&premi_tahun=<%= encodeURIComponent(selectedPremiYear || 'SEMUA') %>&pnbp_tahun=<%= encodeURIComponent(selectedPnbpYear || '') %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/premi/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <input type="hidden" name="premi_search" value="<%= premiSearch || '' %>">
                        <input type="hidden" name="premi_bulan" value="<%= selectedPremiMonth || 'SEMUA' %>">
                        <input type="hidden" name="premi_tahun" value="<%= selectedPremiYear || 'SEMUA' %>">
                        <input type="hidden" name="pnbp_tahun" value="<%= selectedPnbpYear || '' %>">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!premiList.length) { %><tr><td colspan="8" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<script>
  (function () {
    var pnbpTotalsByPeriod = <%- JSON.stringify(pnbpPendapatanTotals || {}) %>;

    var normalizePeriod = function (value) {
      return String(value || '').trim().toUpperCase();
    };

    var parseNumber = function (raw) {
      var text = String(raw || '').trim();
      if (!text) return 0;
      text = text.replace(/[^\d,.-]/g, '');
      if (text.indexOf(',') !== -1 && text.indexOf('.') !== -1) {
        if (text.lastIndexOf(',') > text.lastIndexOf('.')) {
          text = text.replace(/\./g, '').replace(',', '.');
        } else {
          text = text.replace(/,/g, '');
        }
      } else if (text.indexOf(',') !== -1) {
        text = text.replace(/\./g, '').replace(',', '.');
      } else {
        text = text.replace(/,/g, '');
      }
      var value = Number(text);
      return Number.isFinite(value) ? value : 0;
    };

    var formatNumber = function (value) {
      var numeric = Number(value || 0);
      if (!Number.isFinite(numeric)) return '0';
      return Math.round(numeric).toLocaleString('id-ID');
    };

    var formatPercent = function (value) {
      var rounded = Math.round(value * 100) / 100;
      if (Math.abs(rounded - Math.round(rounded)) < 0.001) {
        return String(Math.round(rounded)) + '%';
      }
      return rounded.toFixed(2).replace(/\.00$/, '') + '%';
    };

    var updatePnbpForm = function (form) {
      var jumlahInput = form.querySelector('[data-pnbp-field="jumlah"]');
      var targetInput = form.querySelector('[data-pnbp-field="target"]');
      var persentaseInput = form.querySelector('[data-pnbp-field="persentase"]');
      var keteranganInput = form.querySelector('[data-pnbp-field="keterangan"]');
      if (!jumlahInput || !targetInput || !persentaseInput || !keteranganInput) return;

      var tahunInput = form.querySelector('[name="tahun"]');
      var periodeInput = form.querySelector('[name="periode_pnbp"]');
      var key = (String((tahunInput && tahunInput.value) || '').trim()) + '|' + normalizePeriod((periodeInput && periodeInput.value) || '');
      var sourceAmount = Number(pnbpTotalsByPeriod[key] || 0);
      jumlahInput.value = formatNumber(sourceAmount);

      var jumlah = parseNumber(jumlahInput.value);
      var target = parseNumber(targetInput.value);

      if (target <= 0) {
        persentaseInput.value = '';
        keteranganInput.value = '';
        return;
      }

      var percent = (jumlah / target) * 100;
      persentaseInput.value = formatPercent(percent);
      keteranganInput.value = percent >= 100 ? 'TERCAPAI' : 'BELUM TERCAPAI';
    };

    document.querySelectorAll('form[data-pnbp-auto="true"]').forEach(function (form) {
      var jumlahInput = form.querySelector('[data-pnbp-field="jumlah"]');
      var targetInput = form.querySelector('[data-pnbp-field="target"]');
      var tahunInput = form.querySelector('[name="tahun"]');
      var periodeInput = form.querySelector('[name="periode_pnbp"]');
      if (jumlahInput) {
        jumlahInput.addEventListener('input', function () { updatePnbpForm(form); });
        jumlahInput.addEventListener('change', function () { updatePnbpForm(form); });
      }
      if (targetInput) {
        targetInput.addEventListener('input', function () { updatePnbpForm(form); });
        targetInput.addEventListener('change', function () { updatePnbpForm(form); });
      }
      if (tahunInput) {
        tahunInput.addEventListener('input', function () { updatePnbpForm(form); });
        tahunInput.addEventListener('change', function () { updatePnbpForm(form); });
      }
      if (periodeInput) {
        periodeInput.addEventListener('change', function () { updatePnbpForm(form); });
      }
      updatePnbpForm(form);
    });
  })();
</script>
</body>
</html>
