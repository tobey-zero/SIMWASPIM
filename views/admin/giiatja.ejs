<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GIIATJA – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>🏭 GIIATJA (Kegiatan Kerja)</h2><p>Kelola data kegiatan kerja, pelatihan, PNBP, dan premi WBP</p></div>
      <div class="topbar-actions"><a href="/kalapas/table/giiatja" target="_blank" class="btn-public">🧭 Lihat Tabel Kalapas</a></div>
    </div>

    <div class="content-area">
      <% const pnbpPeriodeOptions = ['JANUARI','FEBRUARI','MARET','APRIL','MEI','JUNI','JULI','AGUSTUS','SEPTEMBER','OKTOBER','NOVEMBER','DESEMBER']; %>
      <% const currentMenu = giiatjaMenu || 'kegiatan'; %>
      <% const isMenu = (name) => currentMenu === name; %>
      <% if (success) { %><div class="alert alert-success">✅ Data GIIATJA berhasil disimpan.</div><% } %>
      <% if (error) { %><div class="alert alert-danger">❌ <%= error %></div><% } %>

      <div class="card">
        <div class="card-body" style="display:flex;gap:8px;flex-wrap:wrap;">
          <a href="/admin/giiatja?menu=kegiatan" class="btn btn-sm <%- isMenu('kegiatan') ? 'btn-primary' : 'btn-secondary' %>">🏭 Kegiatan</a>
          <a href="/admin/giiatja?menu=sarana" class="btn btn-sm <%- isMenu('sarana') ? 'btn-primary' : 'btn-secondary' %>">🧰 Sarana Kerja</a>
          <a href="/admin/giiatja?menu=pelatihan" class="btn btn-sm <%- isMenu('pelatihan') ? 'btn-primary' : 'btn-secondary' %>">🎓 Pelatihan</a>
          <a href="/admin/giiatja?menu=pnbp" class="btn btn-sm <%- isMenu('pnbp') ? 'btn-primary' : 'btn-secondary' %>">💳 PNBP</a>
          <a href="/admin/giiatja?menu=premi" class="btn btn-sm <%- isMenu('premi') ? 'btn-primary' : 'btn-secondary' %>">💰 Premi</a>
          <a href="/admin/giiatja?menu=pemasaran" class="btn btn-sm <%- isMenu('pemasaran') ? 'btn-primary' : 'btn-secondary' %>">🧾 Pemasaran Hasil</a>
        </div>
      </div>

      <div class="card" <%- isMenu('kegiatan') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>➕ Master Kategori Kegiatan</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/kategori/add">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>Kategori</label><input type="text" name="kategori" required placeholder="cth: A (AREA DALAM)"></div>
              <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="1"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Kategori</button>
          </form>
        </div>
      </div>

      <% if (editKategori) { %>
      <div class="edit-panel" <%- isMenu('kegiatan') ? '' : 'style="display:none;"' %>>
        <h4>✏️ Edit Kategori (ID: <%= editKategori.id %>)</h4>
        <form method="POST" action="/admin/giiatja/kategori/<%= editKategori.id %>/update">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>Kategori</label><input type="text" name="kategori" value="<%= editKategori.kategori || '' %>" required></div>
            <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="<%= editKategori.sort_order || 1 %>"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card" <%- isMenu('kegiatan') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>Daftar Kategori (<%= kegiatanCategories.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Kategori</th><th>Urutan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% kegiatanCategories.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.kategori || '-' %></td>
                  <td><%= item.sort_order || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?editKategori=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/kategori/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus kategori ini beserta detail kegiatannya?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!kegiatanCategories.length) { %><tr><td colspan="4" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card" <%- isMenu('kegiatan') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>➕ Detail Kegiatan per Peserta</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/kegiatan/add" enctype="multipart/form-data">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Kategori</label>
                <select name="kegiatan_id" required>
                  <option value="">-- Pilih Kategori --</option>
                  <% kegiatanCategories.forEach(item => { %>
                    <option value="<%= item.id %>"><%= item.kategori %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="1"></div>
              <div class="form-group"><label>Jenis Kegiatan</label><input type="text" name="jenis_kegiatan" required placeholder="cth: PANGKAS"></div>
              <div class="form-group"><label>Nama Peserta</label><textarea name="peserta_kegiatan" rows="3" required placeholder="cth:
WBP A.N. A
WBP B.N. B"></textarea></div>
              <div class="form-group"><label>Pengawas</label><textarea name="pengawas" rows="3" placeholder="cth:
PETUGAS A
PETUGAS B"></textarea></div>
              <div class="form-group"><label>Dokumentasi (opsional)</label><input type="file" name="dokumentasi" accept="image/*"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Detail</button>
          </form>
        </div>
      </div>

      <% if (editKegiatan) { %>
      <div class="edit-panel" <%- isMenu('kegiatan') ? '' : 'style="display:none;"' %>>
        <h4>✏️ Edit Detail Kegiatan (ID: <%= editKegiatan.id %>)</h4>
        <form method="POST" action="/admin/giiatja/kegiatan/<%= editKegiatan.id %>/update" enctype="multipart/form-data">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group">
              <label>Kategori</label>
              <select name="kegiatan_id" required>
                <% kegiatanCategories.forEach(item => { %>
                  <option value="<%= item.id %>" <%= Number(editKegiatan.kegiatan_id)===Number(item.id)?'selected':'' %>><%= item.kategori %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="<%= editKegiatan.sort_order || 1 %>"></div>
            <div class="form-group"><label>Jenis Kegiatan</label><input type="text" name="jenis_kegiatan" value="<%= editKegiatan.jenis_kegiatan || '' %>" required></div>
            <div class="form-group"><label>Nama Peserta</label><textarea name="peserta_kegiatan" rows="3" required><%= editKegiatan.peserta_kegiatan || '' %></textarea></div>
            <div class="form-group"><label>Pengawas</label><textarea name="pengawas" rows="3"><%= editKegiatan.pengawas || '' %></textarea></div>
            <div class="form-group"><label>Dokumentasi Baru (opsional)</label><input type="file" name="dokumentasi" accept="image/*"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card" <%- isMenu('kegiatan') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>Daftar Detail Kegiatan (<%= kegiatanList.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Kategori</th><th>Jenis Kegiatan</th><th>Nama Peserta</th><th>Pengawas</th><th>Dokumentasi</th><th>Aksi</th></tr></thead>
              <tbody>
                <% kegiatanList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.kategori || '-' %></td>
                  <td><%= item.jenis_kegiatan || '-' %></td>
                  <td>
                    <% const pesertaLines = String(item.peserta_kegiatan || '').split(/\r?\n/).map(line => line.trim()).filter(Boolean); %>
                    <% if (pesertaLines.length) { %>
                      <ol style="margin:0; padding-left:18px; white-space:normal;">
                        <% pesertaLines.forEach((line) => { %>
                          <li><%= line %></li>
                        <% }) %>
                      </ol>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% const pengawasLines = String(item.pengawas || '').split(/\r?\n/).map(line => line.trim()).filter(Boolean); %>
                    <% if (pengawasLines.length) { %>
                      <ol style="margin:0; padding-left:18px; white-space:normal;">
                        <% pengawasLines.forEach((line) => { %>
                          <li><%= line %></li>
                        <% }) %>
                      </ol>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% if (item.dokumentasi_path) { %>
                      <a href="<%= item.dokumentasi_path %>" target="_blank" class="btn btn-secondary btn-xs">🔍 Lihat</a>
                    <% } else { %>-<% } %>
                  </td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?editKegiatan=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/kegiatan/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus detail ini?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!kegiatanList.length) { %><tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card" <%- isMenu('sarana') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>➕ Master Perlengkapan Sarana dan Prasarana</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/sarana/master/add">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>Nama Alat</label><input type="text" name="uraian" required placeholder="cth: GERGAJI BESI"></div>
              <div class="form-group"><label>Jumlah Satuan</label><input type="text" name="jumlah_satuan" required placeholder="cth: 12 UNIT"></div>
              <div class="form-group" style="grid-column: span 2;"><label>Penempatan Tiap Kegiatan Kerja</label><textarea name="penempatan_kegiatan" rows="2" required placeholder="cth: PANGKAS, LAS, BENGKEL"></textarea></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Master Sarana</button>
          </form>
        </div>
      </div>

      <% if (editSaranaMaster) { %>
      <div class="edit-panel" <%- isMenu('sarana') ? '' : 'style="display:none;"' %>>
        <h4>✏️ Edit Master Sarana (ID: <%= editSaranaMaster.id %>)</h4>
        <form method="POST" action="/admin/giiatja/sarana/master/<%= editSaranaMaster.id %>/update">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>Nama Alat</label><input type="text" name="uraian" value="<%= editSaranaMaster.uraian || '' %>" required></div>
            <div class="form-group"><label>Jumlah Satuan</label><input type="text" name="jumlah_satuan" value="<%= editSaranaMaster.jumlah_satuan || '' %>" required></div>
            <div class="form-group" style="grid-column: span 2;"><label>Penempatan Tiap Kegiatan Kerja</label><textarea name="penempatan_kegiatan" rows="2" required><%= editSaranaMaster.penempatan_kegiatan || '' %></textarea></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja?menu=sarana" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card" <%- isMenu('sarana') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>Daftar Master Perlengkapan Sarana dan Prasarana (<%= saranaMasterList.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>No</th><th>Nama Alat</th><th>Jumlah Satuan</th><th>Penempatan Tiap Kegiatan Kerja</th><th>Aksi</th></tr></thead>
              <tbody>
                <% saranaMasterList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.uraian || '-' %></td>
                  <td><%= item.jumlah_satuan || '-' %></td>
                  <td style="white-space:pre-line;"><%= item.penempatan_kegiatan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?menu=sarana&editSaranaMaster=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/sarana/master/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus master sarana ini?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!saranaMasterList.length) { %><tr><td colspan="6" style="text-align:center;color:#aaa;padding:20px;">Belum ada data master sarana</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card" <%- isMenu('sarana') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>📅 Filter dan Input Penggunaan Harian Sarana</h3></div>
        <div class="card-body">
          <form method="GET" action="/admin/giiatja" style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;margin-bottom:12px;">
            <input type="hidden" name="menu" value="sarana">
            <div class="form-group" style="margin:0;min-width:240px;">
              <label>Tanggal</label>
              <input type="date" name="tanggal_sarana" value="<%= selectedSaranaDate || '' %>">
            </div>
            <button type="submit" class="btn btn-primary btn-sm">📅 Tampilkan</button>
            <a href="/admin/giiatja?menu=sarana" class="btn btn-secondary btn-sm">↺ Hari Ini</a>
          </form>

          <form method="POST" action="/admin/giiatja/sarana/penggunaan/add">
            <input type="hidden" name="tanggal" value="<%= selectedSaranaDate || '' %>">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Perlengkapan Sarana</label>
                <select name="sarana_id" required>
                  <option value="">-- Pilih Master Sarana --</option>
                  <% saranaMasterList.forEach((item) => { %>
                    <option value="<%= item.id %>"><%= item.uraian %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group"><label>Jumlah Digunakan Harian</label><input type="text" name="jumlah_digunakan" required placeholder="cth: 5 UNIT / HARI"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Penggunaan Harian</button>
          </form>
        </div>
      </div>

      <% if (editSaranaPenggunaan) { %>
      <div class="edit-panel" <%- isMenu('sarana') ? '' : 'style="display:none;"' %>>
        <h4>✏️ Edit Penggunaan Harian Sarana (ID: <%= editSaranaPenggunaan.id %>)</h4>
        <form method="POST" action="/admin/giiatja/sarana/penggunaan/<%= editSaranaPenggunaan.id %>/update">
          <input type="hidden" name="tanggal" value="<%= selectedSaranaDate || editSaranaPenggunaan.tanggal || '' %>">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group">
              <label>Perlengkapan Sarana</label>
              <select name="sarana_id" required>
                <% saranaMasterList.forEach((item) => { %>
                  <option value="<%= item.id %>" <%= Number(editSaranaPenggunaan.sarana_id) === Number(item.id) ? 'selected' : '' %>><%= item.uraian %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group"><label>Jumlah Digunakan Harian</label><input type="text" name="jumlah_digunakan" value="<%= editSaranaPenggunaan.jumlah_digunakan || '' %>" required></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja?menu=sarana&tanggal_sarana=<%= encodeURIComponent(selectedSaranaDate || '') %>" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card" <%- isMenu('sarana') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>Daftar Penggunaan Harian Sarana (<%= saranaPenggunaanList.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>No</th><th>Nama Alat</th><th>Jumlah Satuan</th><th>Penempatan Tiap Kegiatan Kerja</th><th>Jumlah Digunakan Harian</th><th>Aksi</th></tr></thead>
              <tbody>
                <% saranaPenggunaanList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.uraian || '-' %></td>
                  <td><%= item.jumlah_satuan || '-' %></td>
                  <td style="white-space:pre-line;"><%= item.penempatan_kegiatan || '-' %></td>
                  <td><%= item.jumlah_digunakan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?menu=sarana&editSaranaPenggunaan=<%= item.id %>&tanggal_sarana=<%= encodeURIComponent(selectedSaranaDate || '') %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/sarana/penggunaan/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data penggunaan harian ini?')">
                        <input type="hidden" name="tanggal_sarana" value="<%= selectedSaranaDate || '' %>">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!saranaPenggunaanList.length) { %><tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada data penggunaan sarana untuk tanggal ini</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card" <%- isMenu('pelatihan') ? '' : 'style="display:none;"' %>>
        <div class="card-header"><h3>➕ Tabel Pelatihan Bersertifikat</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/pelatihan/add" enctype="multipart/form-data">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi"></div>
              <div class="form-group"><label>Nama WBP</label><input type="text" name="nama_wbp" required></div>
              <div class="form-group"><label>Jenis Pelatihan</label><input type="text" name="jenis_pelatihan"></div>
              <div class="form-group"><label>Tanggal Pelaksanaan</label><input type="text" name="tanggal_pelaksanaan" placeholder="cth: 18 April 2026"></div>
              <div class="form-group"><label>Instruktur</label><input type="text" name="instruktur"></div>
              <div class="form-group"><label>Foto Sertifikat</label><input type="file" name="poto_sertifikat" accept="image/*"></div>
              <div class="form-group" style="grid-column:span 2;"><label>Keterangan</label><input type="text" name="keterangan"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Pelatihan</button>
          </form>
        </div>
      </div>

      <% if (editPelatihan) { %>
      <div class="edit-panel" <%- isMenu('pelatihan') ? '' : 'style="display:none;"' %>>
        <h4>✏️ Edit Pelatihan (ID: <%= editPelatihan.id %>)</h4>
        <form method="POST" action="/admin/giiatja/pelatihan/<%= editPelatihan.id %>/update" enctype="multipart/form-data">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi" value="<%= editPelatihan.no_registrasi || '' %>"></div>
            <div class="form-group"><label>Nama WBP</label><input type="text" name="nama_wbp" value="<%= editPelatihan.nama_wbp || '' %>" required></div>
            <div class="form-group"><label>Jenis Pelatihan</label><input type="text" name="jenis_pelatihan" value="<%= editPelatihan.jenis_pelatihan || '' %>"></div>
            <div class="form-group"><label>Tanggal Pelaksanaan</label><input type="text" name="tanggal_pelaksanaan" value="<%= editPelatihan.tanggal_pelaksanaan || '' %>"></div>
            <div class="form-group"><label>Instruktur</label><input type="text" name="instruktur" value="<%= editPelatihan.instruktur || '' %>"></div>
            <div class="form-group"><label>Foto Sertifikat Baru</label><input type="file" name="poto_sertifikat" accept="image/*"></div>
