<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kelola User – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>👤 Kelola User</h2><p>Manajemen akun pengguna panel admin</p></div>
      <div class="topbar-actions"><a href="/" target="_blank" class="btn-public">🌐 Lihat Publik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data user berhasil disimpan.</div><% } %>
      <% if (error) { %><div class="alert alert-danger">⚠️ <%= error %></div><% } %>

      <!-- Form Tambah User -->
      <div class="card">
        <div class="card-header"><h3>➕ Tambah User Baru</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/users/add">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" placeholder="Username unik" required>
              </div>
              <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Min. 6 karakter" required>
              </div>
              <div class="form-group">
                <label>Role</label>
                <select name="role">
                  <option value="superadmin">SuperAdmin – Akses Penuh</option>
                  <option value="registrasi">Registrasi – Statistik</option>
                  <option value="pembinaan">Pembinaan – Pembinaan & Jadwal</option>
                  <option value="klinik">Klinik – Dashboard</option>
                  <option value="dapur">Dapur – Menu Makan</option>
                  <option value="humas">Humas – Remisi</option>
                  <option value="kamtib">Kamtib – Razia & Strapsel</option>
                  <option value="tata_usaha">TU – Tata Usaha</option>
                  <option value="pengamanan">Pengamanan – Kamar/Blok & Papan Isi</option>
                  <option value="giiatja">GIIATJA – Kegiatan Kerja</option>
                  <option value="kalapas">Kalapas – Tampilan Kalapas</option>
                </select>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah User</button>
          </form>
        </div>
      </div>

      <!-- Form Edit User -->
      <% if (edit) { %>
      <div class="edit-panel">
        <h4>✏️ Edit User (ID: <%= edit.id %>)</h4>
        <form method="POST" action="/admin/users/<%= edit.id %>/update">
          <div class="form-grid col-3" style="margin-bottom:12px;">
            <div class="form-group">
              <label>Username</label>
              <input type="text" name="username" value="<%= edit.username %>" required>
            </div>
            <div class="form-group">
              <label>Password Baru <small style="color:#888">(kosongkan jika tidak diubah)</small></label>
              <input type="password" name="password" placeholder="Kosongkan jika tidak diubah">
            </div>
            <div class="form-group">
              <label>Role</label>
              <select name="role">
                <% [['superadmin','SuperAdmin – Akses Penuh'],['registrasi','Registrasi'],['pembinaan','Pembinaan'],['klinik','Klinik'],['dapur','Dapur'],['humas','Humas'],['kamtib','Kamtib'],['tata_usaha','Tata Usaha'],['pengamanan','Pengamanan'],['giiatja','GIIATJA'],['kalapas','Kalapas – Tampilan Kalapas']].forEach(([v,l]) => { %>
                <option value="<%= v %>" <%= edit.role===v?'selected':'' %>><%= l %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/users" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <!-- Tabel User -->
      <div class="card">
        <div class="card-header"><h3>Daftar User (<%= list.length %> akun)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Username</th><th>Role</th><th>Dibuat</th><th>Aksi</th></tr></thead>
              <tbody>
                <% list.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><strong><%= item.username %></strong></td>
                  <td><span class="badge badge-<%= item.role %>"><%= item.role %></span></td>
                  <td><%= item.created_at %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/users?edit=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <% if (item.id !== user.id) { %>
                      <form method="POST" action="/admin/users/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus user ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                      <% } else { %>
                      <span style="font-size:10px;color:#888">(akun Anda)</span>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="alert alert-info" style="margin-top:0;">
        ℹ️ <strong>Catatan keamanan:</strong> Ganti password default <code>admin123</code> setelah pertama kali login.
      </div>
    </div>
  </div>
</div>
</body>
</html>
