<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WBP Luar Tembok – Admin Pengamanan</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>🧾 WBP di Luar Tembok</h2><p>Kelola data WBP luar tembok khusus pengamanan</p></div>
      <div class="topbar-actions"><a href="/kalapas/table/luar-tembok" target="_blank" class="btn-public">🌐 Lihat Tabel Publik</a></div>
    </div>

    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>

      <div class="card">
        <div class="card-header"><h3>📅 Filter Tanggal</h3></div>
        <div class="card-body">
          <form method="GET" action="/admin/luar-tembok" style="display:flex;gap:8px;align-items:end;flex-wrap:wrap;">
            <div class="form-group" style="margin:0;min-width:220px;">
              <label>Tampilkan tanggal</label>
              <input type="date" name="tanggal" value="<%= selectedDate || todayYmd %>" required>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">Terapkan</button>
            <a href="/admin/luar-tembok" class="btn btn-secondary btn-sm">Hari Ini</a>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3><%= edit ? '✏️ Edit WBP Luar Tembok' : '➕ Tambah WBP Luar Tembok' %></h3></div>
        <div class="card-body">
          <form method="POST" action="<%= edit ? '/admin/luar-tembok/' + edit.id + '/update' : '/admin/luar-tembok/add' %>">
            <input type="hidden" name="redirect_tanggal" value="<%= selectedDate || todayYmd %>">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi" required value="<%= edit ? edit.no_registrasi : '' %>" placeholder="BI.001-LT/2026"></div>
              <div class="form-group"><label>Nama</label><input type="text" name="nama" required value="<%= edit ? edit.nama : '' %>" placeholder="Nama WBP"></div>
              <div class="form-group"><label>Tanggal</label><input type="date" name="tanggal" required value="<%= edit ? editTanggalInput : todayYmd %>"></div>
              <div class="form-group"><label>Pendamping</label><input type="text" name="pendamping" required value="<%= edit ? edit.pendamping : '' %>" placeholder="Nama Pendamping"></div>
              <div class="form-group" style="grid-column: span 4;"><label>Keterangan</label><input type="text" name="keterangan" value="<%= edit ? (edit.keterangan || '') : '' %>" placeholder="cth: Kebersihan Luar Tembok"></div>
            </div>
            <div style="display:flex;gap:8px;">
              <button type="submit" class="btn <%= edit ? 'btn-success' : 'btn-primary' %> btn-sm"><%= edit ? '💾 Simpan' : '➕ Tambah' %></button>
              <% if (edit) { %><a href="/admin/luar-tembok?tanggal=<%= encodeURIComponent(selectedDate || todayYmd) %>" class="btn btn-secondary btn-sm">✕ Batal</a><% } %>
            </div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>Daftar WBP Luar Tembok (<%= list.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>No Registrasi</th><th>Nama</th><th>Tanggal</th><th>Pendamping</th><th>Keterangan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% list.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.no_registrasi %></td>
                  <td><%= item.nama %></td>
                  <td><%= formatDateIndo(item.tanggal) %></td>
                  <td><%= item.pendamping %></td>
                  <td><%= item.keterangan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/luar-tembok?edit=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/luar-tembok/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <input type="hidden" name="redirect_tanggal" value="<%= selectedDate || todayYmd %>">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!list.length) { %><tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
</body>
</html>
