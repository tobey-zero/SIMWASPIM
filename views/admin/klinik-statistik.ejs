<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Statistik Klinik – Admin Klinik</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>📊 Statistik Klinik</h2><p>Update data statistik kesehatan WBP</p></div>
      <div class="topbar-actions"><a href="/klinik" target="_blank" class="btn-public">🌐 Lihat Klinik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>

      <div class="card">
        <div class="card-header"><h3>📝 Update Statistik Klinik</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/klinik-statistik/update">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>WBP di Blok Lansia</label>
                <input type="number" name="blok_lansia" value="<%= data.blok_lansia %>" min="0" required>
              </div>
              <div class="form-group">
                <label>WBP TB</label>
                <input type="number" name="tb" value="<%= data.tb %>" min="0" required>
              </div>
              <div class="form-group">
                <label>WBP Paru</label>
                <input type="number" name="paru" value="<%= data.paru %>" min="0" required>
              </div>
              <div class="form-group">
                <label>WBP HIV</label>
                <input type="number" name="hiv" value="<%= data.hiv %>" min="0" required>
              </div>
              <div class="form-group">
                <label>Penyakit Lainnya</label>
                <input type="number" name="lainnya" value="<%= data.lainnya %>" min="0" required>
              </div>
              <div class="form-group">
                <label>Rawat Inap</label>
                <input type="number" name="rawat_inap" value="<%= data.rawat_inap %>" min="0" required>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">💾 Simpan Perubahan</button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>📋 Ringkasan Saat Ini</h3></div>
        <div class="card-body">
          <div class="form-grid col-3">
            <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:16px;text-align:center;">
              <div style="font-size:11px;color:#6b7280;font-weight:bold;margin-bottom:4px;">Blok Lansia</div>
              <div style="font-size:28px;font-weight:bold;color:#1a365d;"><%= data.blok_lansia %></div>
            </div>
            <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:8px;padding:16px;text-align:center;">
              <div style="font-size:11px;color:#6b7280;font-weight:bold;margin-bottom:4px;">Total Penyakit Kronis</div>
              <div style="font-size:28px;font-weight:bold;color:#92400e;"><%= data.tb + data.paru + data.hiv + data.lainnya %></div>
            </div>
            <div style="background:#fce4ec;border:1px solid #f48fb1;border-radius:8px;padding:16px;text-align:center;">
              <div style="font-size:11px;color:#6b7280;font-weight:bold;margin-bottom:4px;">Rawat Inap</div>
              <div style="font-size:28px;font-weight:bold;color:#c62828;"><%= data.rawat_inap %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
