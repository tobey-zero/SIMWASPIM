<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Papan Keadaan Isi – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>📌 Papan Keadaan Isi Lapas</h2><p>Kelola data papan harian sesuai format lapangan</p></div>
      <div class="topbar-actions"><a href="/kalapas/papan-isi" target="_blank" class="btn-public">🧭 Lihat Papan Kalapas</a></div>
    </div>

    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>
      <% if (!hasPapanIsiTodayUpdate) { %>
        <div class="alert" style="background:#fff4e5;color:#9a3412;border:1px solid #fdba74;">
          ⚠️ Data Registrasi Hunian sudah direset ke 0 untuk hari ini. Silakan isi data terbaru sekarang.
        </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3><%= editRegistrasi ? '✏️ Edit Registrasi Hunian' : '➕ Tambah Registrasi Hunian' %></h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editRegistrasi ? '/admin/papan-isi/registrasi/' + editRegistrasi.id + '/update' : '/admin/papan-isi/registrasi/add' %>">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>No</label><input type="number" min="1" name="no_urut" required value="<%= editRegistrasi ? editRegistrasi.no_urut : '' %>" placeholder="1 / 2"></div>
              <div class="form-group"><label>Blok</label><input type="text" name="blok" required value="<%= editRegistrasi ? editRegistrasi.blok : '' %>" placeholder="A / B"></div>
              <div class="form-group"><label>Registrasi</label><input type="text" name="registrasi" required value="<%= editRegistrasi ? editRegistrasi.registrasi : '' %>" placeholder="A.I / B.I"></div>
              <div class="form-group"><label>WNI Isi</label><input type="number" min="0" name="wni_isi" required value="<%= editRegistrasi ? editRegistrasi.wni_isi : 0 %>"></div>
              <div class="form-group"><label>WNI Tambah</label><input type="number" min="0" name="wni_tambah" required value="<%= editRegistrasi ? editRegistrasi.wni_tambah : 0 %>"></div>
              <div class="form-group"><label>WNI Kurang</label><input type="number" min="0" name="wni_kurang" required value="<%= editRegistrasi ? editRegistrasi.wni_kurang : 0 %>"></div>
              <div class="form-group"><label>WNA Isi</label><input type="number" min="0" name="wna_isi" required value="<%= editRegistrasi ? editRegistrasi.wna_isi : 0 %>"></div>
              <div class="form-group"><label>WNA Tambah</label><input type="number" min="0" name="wna_tambah" required value="<%= editRegistrasi ? editRegistrasi.wna_tambah : 0 %>"></div>
              <div class="form-group"><label>WNA Kurang</label><input type="number" min="0" name="wna_kurang" required value="<%= editRegistrasi ? editRegistrasi.wna_kurang : 0 %>"></div>
            </div>
            <div style="display:flex;gap:8px;">
              <button type="submit" class="btn <%= editRegistrasi ? 'btn-success' : 'btn-primary' %> btn-sm"><%= editRegistrasi ? '💾 Simpan' : '➕ Tambah' %></button>
              <% if (editRegistrasi) { %><a href="/admin/papan-isi" class="btn btn-secondary btn-sm">✕ Batal</a><% } %>
            </div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3><%= editWnaNegara ? '✏️ Edit Data WNA' : '➕ Tambah Data WNA' %></h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editWnaNegara ? '/admin/papan-isi/wna-negara/' + editWnaNegara.id + '/update' : '/admin/papan-isi/wna-negara/add' %>">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi" required value="<%= editWnaNegara ? editWnaNegara.no_registrasi : '' %>" placeholder="Contoh: BI.100-WNA/2026"></div>
              <div class="form-group"><label>Nama WBP</label><input type="text" name="nama_wbp" required value="<%= editWnaNegara ? editWnaNegara.nama_wbp : '' %>" placeholder="Contoh: JOHN DOE"></div>
              <div class="form-group"><label>Asal Negara</label><input type="text" name="asal_negara" required value="<%= editWnaNegara ? editWnaNegara.asal_negara : '' %>" placeholder="Contoh: MALAYSIA"></div>
              <div class="form-group"><label>Tindak Pidana</label><input type="text" name="tindak_pidana" required value="<%= editWnaNegara ? editWnaNegara.tindak_pidana : '' %>" placeholder="Contoh: NARKOTIKA"></div>
            </div>
            <div style="display:flex;gap:8px;">
              <button type="submit" class="btn <%= editWnaNegara ? 'btn-success' : 'btn-primary' %> btn-sm"><%= editWnaNegara ? '💾 Simpan' : '➕ Tambah' %></button>
              <% if (editWnaNegara) { %><a href="/admin/papan-isi" class="btn btn-secondary btn-sm">✕ Batal</a><% } %>
            </div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3><%= editPidana ? '✏️ Edit Data Jenis Tindak Pidana' : '➕ Tambah Jenis Tindak Pidana' %></h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editPidana ? '/admin/papan-isi/pidana/' + editPidana.id + '/update' : '/admin/papan-isi/pidana/add' %>">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Kategori</label>
                <select name="kategori" required>
                  <option value="khusus" <%= editPidana && editPidana.kategori === 'khusus' ? 'selected' : '' %>>Pidana Khusus</option>
                  <option value="umum" <%= editPidana && editPidana.kategori === 'umum' ? 'selected' : '' %>>Pidana Umum</option>
                </select>
              </div>
              <div class="form-group"><label>Jenis</label><input type="text" name="jenis" required value="<%= editPidana ? editPidana.jenis : '' %>"></div>
              <div class="form-group"><label>Jumlah</label><input type="number" min="0" name="jumlah" required value="<%= editPidana ? editPidana.jumlah : 0 %>"></div>
            </div>
            <div style="display:flex;gap:8px;">
              <button type="submit" class="btn <%= editPidana ? 'btn-success' : 'btn-primary' %> btn-sm"><%= editPidana ? '💾 Simpan' : '➕ Tambah' %></button>
              <% if (editPidana) { %><a href="/admin/papan-isi" class="btn btn-secondary btn-sm">✕ Batal</a><% } %>
            </div>
          </form>
        </div>
      </div>


      <div class="card">
        <div class="card-header"><h3><%= editLuar ? '✏️ Edit WBP di Luar Lapas' : '➕ Tambah WBP di Luar Lapas' %></h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editLuar ? '/admin/papan-isi/luar/' + editLuar.id + '/update' : '/admin/papan-isi/luar/add' %>">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>Status</label><input type="text" name="status" required value="<%= editLuar ? editLuar.status : '' %>"></div>
              <div class="form-group"><label>WNI Keluar</label><input type="number" min="0" name="wni_keluar" required value="<%= editLuar ? editLuar.wni_keluar : 0 %>"></div>
              <div class="form-group"><label>WNI Masuk</label><input type="number" min="0" name="wni_masuk" required value="<%= editLuar ? editLuar.wni_masuk : 0 %>"></div>
              <div class="form-group"><label>WNA Keluar</label><input type="number" min="0" name="wna_keluar" required value="<%= editLuar ? editLuar.wna_keluar : 0 %>"></div>
              <div class="form-group"><label>WNA Masuk</label><input type="number" min="0" name="wna_masuk" required value="<%= editLuar ? editLuar.wna_masuk : 0 %>"></div>
              <div class="form-group" style="grid-column: span 3;"><label>Keterangan</label><input type="text" name="keterangan" value="<%= editLuar ? (editLuar.keterangan || '') : '' %>"></div>
            </div>
            <div style="display:flex;gap:8px;">
              <button type="submit" class="btn <%= editLuar ? 'btn-success' : 'btn-primary' %> btn-sm"><%= editLuar ? '💾 Simpan' : '➕ Tambah' %></button>
              <% if (editLuar) { %><a href="/admin/papan-isi" class="btn btn-secondary btn-sm">✕ Batal</a><% } %>
            </div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3><%= editAgama ? '✏️ Edit Data Agama' : '➕ Tambah Data Agama' %></h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editAgama ? '/admin/papan-isi/agama/' + editAgama.id + '/update' : '/admin/papan-isi/agama/add' %>">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group"><label>Agama</label><input type="text" name="agama" required value="<%= editAgama ? editAgama.agama : '' %>"></div>
              <div class="form-group"><label>WNI</label><input type="number" min="0" name="wni" required value="<%= editAgama ? editAgama.wni : 0 %>"></div>
              <div class="form-group"><label>WNA</label><input type="number" min="0" name="wna" required value="<%= editAgama ? editAgama.wna : 0 %>"></div>
            </div>
            <div style="display:flex;gap:8px;">
              <button type="submit" class="btn <%= editAgama ? 'btn-success' : 'btn-primary' %> btn-sm"><%= editAgama ? '💾 Simpan' : '➕ Tambah' %></button>
              <% if (editAgama) { %><a href="/admin/papan-isi" class="btn btn-secondary btn-sm">✕ Batal</a><% } %>
            </div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>Registrasi Hunian (Format Papan Fisik)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th><th>No</th><th>Blok</th><th>Registrasi</th>
                  <th>WNI Isi</th><th>WNI Tambah</th><th>WNI Kurang</th>
                  <th>WNA Isi</th><th>WNA Tambah</th><th>WNA Kurang</th>
                  <th>Jumlah</th><th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% registrasiHunian.forEach((item, i) => { const jumlah = (Number(item.wniIsi)||0) + (Number(item.wniTambah)||0) + (Number(item.wnaIsi)||0) + (Number(item.wnaTambah)||0); %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.noUrut %></td>
                  <td><%= item.blok %></td>
                  <td><%= item.registrasi %></td>
                  <td><%= item.wniIsi %></td>
                  <td><%= item.wniTambah %></td>
                  <td><%= item.wniKurang %></td>
                  <td><%= item.wnaIsi %></td>
                  <td><%= item.wnaTambah %></td>
                  <td><%= item.wnaKurang %></td>
                  <td><%= jumlah %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/papan-isi?editRegistrasi=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/papan-isi/registrasi/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!registrasiHunian.length) { %><tr><td colspan="12" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>Daftar WNA</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>No Registrasi</th><th>Nama WBP</th><th>Asal Negara</th><th>Tindak Pidana</th><th>Aksi</th></tr></thead>
              <tbody>
                <% wnaNegara.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.noRegistrasi || '-' %></td>
                  <td><%= item.namaWbp || '-' %></td>
                  <td><%= item.asalNegara || '-' %></td>
                  <td><%= item.tindakPidana || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/papan-isi?editWnaNegara=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/papan-isi/wna-negara/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!wnaNegara.length) { %><tr><td colspan="6" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>Jenis Tindak Pidana</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Kategori</th><th>Jenis</th><th>Jumlah</th><th>Aksi</th></tr></thead>
              <tbody>
                <% [...pidanaKhusus, ...pidanaUmum].forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.kategori === 'khusus' ? 'Pidana Khusus' : 'Pidana Umum' %></td>
                  <td><%= item.jenis %></td>
                  <td><%= item.jumlah %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/papan-isi?editPidana=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/papan-isi/pidana/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (![...pidanaKhusus, ...pidanaUmum].length) { %><tr><td colspan="5" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>WBP di Luar Lapas</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Status</th><th>WNI Keluar</th><th>WNI Masuk</th><th>WNA Keluar</th><th>WNA Masuk</th><th>Keterangan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% luarTembok.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.status %></td>
                  <td><%= item.wniKeluar %></td>
                  <td><%= item.wniMasuk %></td>
                  <td><%= item.wnaKeluar %></td>
                  <td><%= item.wnaMasuk %></td>
                  <td><%= item.keterangan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/papan-isi?editLuar=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/papan-isi/luar/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!luarTembok.length) { %><tr><td colspan="8" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>Jumlah WBP Berdasarkan Agama</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Agama</th><th>WNI</th><th>WNA</th><th>Jumlah</th><th>Aksi</th></tr></thead>
              <tbody>
                <% agama.forEach((item, i) => { const jumlah = (Number(item.wni) || 0) + (Number(item.wna) || 0); %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.agama %></td>
                  <td><%= item.wni %></td>
                  <td><%= item.wna %></td>
                  <td><%= jumlah %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/papan-isi?editAgama=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/papan-isi/agama/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!agama.length) { %><tr><td colspan="6" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
</body>
</html>
