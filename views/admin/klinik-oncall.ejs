<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jadwal On Call – Admin Klinik</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>📞 Jadwal On Call Petugas</h2><p>Kelola jadwal on-call tenaga medis</p></div>
      <div class="topbar-actions"><a href="/klinik" target="_blank" class="btn-public">🌐 Lihat Klinik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>

      <div class="card">
        <div class="card-header"><h3>➕ Tambah Jadwal On Call</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/klinik-oncall/add">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Hari</label>
                <select name="hari" required>
                  <option value="Senin">Senin</option>
                  <option value="Selasa">Selasa</option>
                  <option value="Rabu">Rabu</option>
                  <option value="Kamis">Kamis</option>
                  <option value="Jumat">Jumat</option>
                  <option value="Sabtu">Sabtu</option>
                  <option value="Minggu">Minggu</option>
                </select>
              </div>
              <div class="form-group">
                <label>Shift</label>
                <select name="shift" required>
                  <option value="Pagi">Pagi</option>
                  <option value="Siang">Siang</option>
                  <option value="Malam">Malam</option>
                </select>
              </div>
              <div class="form-group">
                <label>Petugas</label>
                <input type="text" name="petugas" placeholder="Nama petugas" required>
              </div>
              <div class="form-group">
                <label>Profesi</label>
                <input type="text" name="profesi" placeholder="cth: Dokter, Perawat" required>
              </div>
              <div class="form-group">
                <label>Kontak</label>
                <input type="text" name="kontak" placeholder="No. HP">
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah</button>
          </form>
        </div>
      </div>

      <% if (edit) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Jadwal On Call (ID: <%= edit.id %>)</h4>
        <form method="POST" action="/admin/klinik-oncall/<%= edit.id %>/update">
          <div class="form-grid col-3" style="margin-bottom:12px;">
            <div class="form-group">
              <label>Hari</label>
              <select name="hari" required>
                <% ['Senin','Selasa','Rabu','Kamis','Jumat','Sabtu','Minggu'].forEach(h => { %>
                <option value="<%= h %>" <%= edit.hari===h?'selected':'' %>><%= h %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>Shift</label>
              <select name="shift" required>
                <% ['Pagi','Siang','Malam'].forEach(s => { %>
                <option value="<%= s %>" <%= edit.shift===s?'selected':'' %>><%= s %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>Petugas</label>
              <input type="text" name="petugas" value="<%= edit.petugas %>" required>
            </div>
            <div class="form-group">
              <label>Profesi</label>
              <input type="text" name="profesi" value="<%= edit.profesi %>" required>
            </div>
            <div class="form-group">
              <label>Kontak</label>
              <input type="text" name="kontak" value="<%= edit.kontak %>">
            </div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/klinik-oncall" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Jadwal On Call (<%= list.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr><th>#</th><th>Hari</th><th>Shift</th><th>Petugas</th><th>Profesi</th><th>Kontak</th><th>Aksi</th></tr>
              </thead>
              <tbody>
                <% list.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.hari %></td>
                  <td><%= item.shift %></td>
                  <td><%= item.petugas %></td>
                  <td><%= item.profesi %></td>
                  <td><%= item.kontak %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/klinik-oncall?edit=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/klinik-oncall/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button type="submit" class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!list.length) { %>
                <tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
