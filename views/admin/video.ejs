<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Media Dokumentasi – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .media-preview { margin-top: 12px; border-radius: 8px; width: 220px; height: 140px; object-fit: cover; border: 1px solid #cbd5e1; background: #000; }
  </style>
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>🎬 Media Dokumentasi</h2><p>Kelola beberapa foto/video untuk ditampilkan bergantian di halaman publik</p></div>
      <div class="topbar-actions"><a href="/" target="_blank" class="btn-public">🌐 Lihat Publik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %>
      <div class="alert alert-success">✅ Media berhasil disimpan.</div>
      <% } %>
      <% if (error) { %>
      <div class="alert alert-danger">❌ <%= error %></div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>➕ Tambah Media</h3><p>Urutan kecil ditampilkan lebih dulu. Durasi dipakai saat media adalah foto.</p></div>
        <div class="card-body">
          <form method="POST" action="/admin/video/add" enctype="multipart/form-data">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>File Media (Foto / Video)</label>
                <input id="add-media-input" type="file" name="media" accept="image/*,video/*" required>
              </div>
              <div class="form-group">
                <label>Urutan Tampil</label>
                <input type="number" min="1" name="sort_order" value="<%= nextOrder %>" required>
              </div>
              <div id="add-duration-group" class="form-group" style="display:none;">
                <label>Durasi Foto (detik)</label>
                <input id="add-duration-input" type="number" min="1" name="display_duration_sec" value="8" disabled>
              </div>
            </div>
            <button type="submit" class="btn btn-primary">📤 Upload Media</button>
          </form>
        </div>
      </div>

      <% if (edit) { %>
      <div class="card">
        <div class="card-header"><h3>✏️ Edit Pengaturan Media</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/video/<%= edit.id %>/update">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Jenis Media</label>
                <input type="text" value="<%= edit.mediaType === 'video' ? 'Video' : 'Foto' %>" disabled>
              </div>
              <div class="form-group">
                <label>Urutan Tampil</label>
                <input type="number" min="1" name="sort_order" value="<%= edit.sortOrder %>" required>
              </div>
              <% if (edit.mediaType === 'image') { %>
                <div class="form-group">
                  <label>Durasi Foto (detik)</label>
                  <input type="number" min="1" name="display_duration_sec" value="<%= edit.displayDurationSec %>" required>
                </div>
              <% } else { %>
                <div class="form-group">
                  <label>Durasi Video</label>
                  <input type="text" value="Tidak digunakan (video diputar sampai selesai)" disabled>
                  <input type="hidden" name="display_duration_sec" value="<%= edit.displayDurationSec %>">
                </div>
              <% } %>
            </div>
            <div style="display:flex;gap:8px;">
              <button type="submit" class="btn btn-success">💾 Simpan</button>
              <a href="/admin/video" class="btn btn-secondary">✕ Batal</a>
            </div>
          </form>

          <% if (edit.mediaType === 'video') { %>
            <video src="<%= edit.mediaPath %>" controls class="media-preview"></video>
          <% } else { %>
            <img src="<%= edit.mediaPath %>" alt="Preview media" class="media-preview">
          <% } %>
        </div>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Playlist Media (<%= list.length %> item)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Preview</th>
                  <th>Jenis</th>
                  <th>Urutan</th>
                  <th>Durasi Foto</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% list.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td>
                    <% if (item.mediaType === 'video') { %>
                      <video src="<%= item.mediaPath %>" controls style="width:140px;height:90px;object-fit:cover;border-radius:6px;"></video>
                    <% } else { %>
                      <img src="<%= item.mediaPath %>" alt="Media" style="width:140px;height:90px;object-fit:cover;border-radius:6px;">
                    <% } %>
                  </td>
                  <td><%= item.mediaType === 'video' ? 'Video' : 'Foto' %></td>
                  <td><%= item.sortOrder %></td>
                  <td><%= item.mediaType === 'image' ? (item.displayDurationSec + ' detik') : '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/video?edit=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/video/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus media ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!list.length) { %>
                <tr><td colspan="6" style="text-align:center;color:#aaa;padding:20px;">Belum ada media</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  (function () {
    const mediaInput = document.getElementById('add-media-input');
    const durationGroup = document.getElementById('add-duration-group');
    const durationInput = document.getElementById('add-duration-input');

    if (!mediaInput || !durationGroup || !durationInput) return;

    function updateDurationVisibility() {
      const file = mediaInput.files && mediaInput.files[0] ? mediaInput.files[0] : null;
      const isImage = !!file && (file.type || '').startsWith('image/');

      durationGroup.style.display = isImage ? '' : 'none';
      durationInput.disabled = !isImage;
      durationInput.required = isImage;
    }

    mediaInput.addEventListener('change', updateDurationVisibility);
    updateDurationVisibility();
  })();
</script>
</body>
</html>
