<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Data Kepegawaian TU – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .tbl-sort-wrap { display:inline-flex; align-items:center; gap:6px; flex-wrap:wrap; }
    .tbl-sort-icons { display:inline-flex; gap:4px; align-items:center; }
    .tbl-sort-icon {
      text-decoration:none;
      font-size:12px;
      font-weight:700;
      color:#94a3b8;
      background:transparent;
      border:0;
      padding:0 2px;
      line-height:1.2;
    }
    .tbl-sort-icon.active { color:#2563eb; }
  </style>
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>👥 Data Kepegawaian</h2><p>Kelola data kepegawaian Tata Usaha</p></div>
      <div class="topbar-actions"><a href="/kalapas/table/tu-umum" target="_blank" class="btn-public">🧭 Lihat Tabel Kalapas</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>

      <div class="card">
        <div class="card-header"><h3>➕ Tambah Data Kepegawaian</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/tu-umum/pegawai/add<%= filterQuery || '' %>">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>Nama Pegawai</label><input type="text" name="nama_pegawai" required></div>
              <div class="form-group"><label>NIP</label><input type="text" name="nip"></div>
              <div class="form-group"><label>Pangkat/Gol</label><input type="text" name="pangkat_gol"></div>
              <div class="form-group"><label>TMT Pangkat</label><input type="date" name="tmt_pangkat"></div>
              <div class="form-group"><label>Jabatan</label><input type="text" name="jabatan"></div>
              <div class="form-group"><label>TMT Jabatan</label><input type="date" name="tmt_jabatan"></div>
              <div class="form-group"><label>Agama</label><input type="text" name="agama"></div>
              <div class="form-group"><label>Status</label><input type="text" name="status"></div>
              <div class="form-group"><label>Pendidikan</label><input type="text" name="pendidikan"></div>
              <div class="form-group"><label>Penempatan/Seksi</label><input type="text" name="penempatan_seksi"></div>
              <div class="form-group"><label>Penempatan/Bidang</label><input type="text" name="penempatan_bidang"></div>
              <div class="form-group"><label>Jenis Kelamin</label><input type="text" name="jenis_kelamin"></div>
              <div class="form-group"><label>Type Pegawai</label><input type="text" name="type_pegawai"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Pegawai</button>
          </form>
        </div>
      </div>

      <% if (editPegawai) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Data Kepegawaian (ID: <%= editPegawai.id %>)</h4>
        <form method="POST" action="/admin/tu-umum/pegawai/<%= editPegawai.id %>/update<%= filterQuery || '' %>">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>Nama Pegawai</label><input type="text" name="nama_pegawai" value="<%= editPegawai.nama_pegawai %>" required></div>
            <div class="form-group"><label>NIP</label><input type="text" name="nip" value="<%= editPegawai.nip || '' %>"></div>
            <div class="form-group"><label>Pangkat/Gol</label><input type="text" name="pangkat_gol" value="<%= editPegawai.pangkat_gol || '' %>"></div>
            <div class="form-group"><label>TMT Pangkat</label><input type="date" name="tmt_pangkat" value="<%= editPegawai.tmt_pangkat || '' %>"></div>
            <div class="form-group"><label>Jabatan</label><input type="text" name="jabatan" value="<%= editPegawai.jabatan || '' %>"></div>
            <div class="form-group"><label>TMT Jabatan</label><input type="date" name="tmt_jabatan" value="<%= editPegawai.tmt_jabatan || '' %>"></div>
            <div class="form-group"><label>Agama</label><input type="text" name="agama" value="<%= editPegawai.agama || '' %>"></div>
            <div class="form-group"><label>Status</label><input type="text" name="status" value="<%= editPegawai.status || '' %>"></div>
            <div class="form-group"><label>Pendidikan</label><input type="text" name="pendidikan" value="<%= editPegawai.pendidikan || '' %>"></div>
            <div class="form-group"><label>Penempatan/Seksi</label><input type="text" name="penempatan_seksi" value="<%= editPegawai.penempatan_seksi || '' %>"></div>
            <div class="form-group"><label>Penempatan/Bidang</label><input type="text" name="penempatan_bidang" value="<%= editPegawai.penempatan_bidang || '' %>"></div>
            <div class="form-group"><label>Jenis Kelamin</label><input type="text" name="jenis_kelamin" value="<%= editPegawai.jenis_kelamin || '' %>"></div>
            <div class="form-group"><label>Type Pegawai</label><input type="text" name="type_pegawai" value="<%= editPegawai.type_pegawai || '' %>"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/tu-umum/kepegawaian<%= filterQuery || '' %>" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Kepegawaian (<%= pegawaiList.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>No</th>
                  <th>Nama Pegawai</th>
                  <th>NIP</th>
                  <th>Pangkat/Gol</th>
                  <th>
                    <span class="tbl-sort-wrap">
                      <span>TMT Pangkat</span>
                      <span class="tbl-sort-icons">
                        <a href="/admin/tu-umum/kepegawaian?sortBy=tmt_pangkat&sortDir=asc" class="tbl-sort-icon <%= sortBy === 'tmt_pangkat' && sortDir === 'asc' ? 'active' : '' %>" title="Urut naik">↑</a>
                        <a href="/admin/tu-umum/kepegawaian?sortBy=tmt_pangkat&sortDir=desc" class="tbl-sort-icon <%= sortBy === 'tmt_pangkat' && sortDir === 'desc' ? 'active' : '' %>" title="Urut turun">↓</a>
                      </span>
                    </span>
                  </th>
                  <th>Jabatan</th>
                  <th>
                    <span class="tbl-sort-wrap">
                      <span>TMT Jabatan</span>
                      <span class="tbl-sort-icons">
                        <a href="/admin/tu-umum/kepegawaian?sortBy=tmt_jabatan&sortDir=asc" class="tbl-sort-icon <%= sortBy === 'tmt_jabatan' && sortDir === 'asc' ? 'active' : '' %>" title="Urut naik">↑</a>
                        <a href="/admin/tu-umum/kepegawaian?sortBy=tmt_jabatan&sortDir=desc" class="tbl-sort-icon <%= sortBy === 'tmt_jabatan' && sortDir === 'desc' ? 'active' : '' %>" title="Urut turun">↓</a>
                      </span>
                    </span>
                  </th>
                  <th>Agama</th>
                  <th>Status</th>
                  <th>Pendidikan</th>
                  <th>Penempatan/Seksi</th>
                  <th>Penempatan/Bidang</th>
                  <th>Jenis Kelamin</th>
                  <th>Type Pegawai</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% pegawaiList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.nama_pegawai || '-' %></td>
                  <td><%= item.nip || '-' %></td>
                  <td><%= item.pangkat_gol || '-' %></td>
                  <td><%= item.tmt_pangkat ? formatDateIndo(item.tmt_pangkat) : '-' %></td>
                  <td><%= item.jabatan || '-' %></td>
                  <td><%= item.tmt_jabatan ? formatDateIndo(item.tmt_jabatan) : '-' %></td>
                  <td><%= item.agama || '-' %></td>
                  <td><%= item.status || '-' %></td>
                  <td><%= item.pendidikan || '-' %></td>
                  <td><%= item.penempatan_seksi || '-' %></td>
                  <td><%= item.penempatan_bidang || '-' %></td>
                  <td><%= item.jenis_kelamin || '-' %></td>
                  <td><%= item.type_pegawai || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/tu-umum/kepegawaian?editPegawai=<%= item.id %><%= filterQueryWithAmp || '' %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/tu-umum/pegawai/<%= item.id %>/delete<%= filterQuery || '' %>" style="display:inline" onsubmit="return confirm('Hapus data pegawai ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!pegawaiList.length) { %><tr><td colspan="15" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
</body>
</html>
