<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menu Makan – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <% const isMaster = menuSection === 'master'; %>
    <% const isTemplate = menuSection === 'template'; %>
    <% const isMakanan = menuSection === 'makanan'; %>
    <% const isJadwal = menuSection === 'jadwal'; %>
    <% const isDistribusi = menuSection === 'distribusi'; %>
    <% const isPermintaan = menuSection === 'permintaan'; %>
    <% const isDiterima = menuSection === 'diterima'; %>
    <% const isPenyimpanan = menuSection === 'penyimpanan'; %>
    <div class="topbar">
      <div class="topbar-title">
        <h2>🍽 Menu Makan</h2>
        <p>
          <%= isMaster ? 'Kelola data Master Menu dasar untuk dapur' : '' %>
          <%= isTemplate ? 'Kelola Template Hari agar menu tidak perlu disusun ulang' : '' %>
          <%= isMakanan ? 'Tetapkan Menu Makanan harian cukup pilih tanggal + template' : '' %>
          <%= isJadwal ? 'Kelola petugas dapur dan jadwal tugas harian' : '' %>
          <%= isDistribusi ? 'Entri distribusi makanan per sesi (08:00, 12:00, 16:00)' : '' %>
          <%= isPermintaan ? 'Input daftar permintaan bahan makanan harian' : '' %>
          <%= isDiterima ? 'Input berita acara penerimaan bahan makanan' : '' %>
          <%= isPenyimpanan ? 'Input daftar penyimpanan bahan makanan harian' : '' %>
        </p>
      </div>
      <div class="topbar-actions"><a href="/" target="_blank" class="btn-public">🌐 Lihat Publik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>
      <% if (titleSuccess) { %><div class="alert alert-success">✅ Judul menu berhasil diperbarui.</div><% } %>
      <% if (error) { %><div class="alert alert-danger">❌ <%= error %></div><% } %>

      <div class="card">
        <div class="card-body" style="display:flex; gap:8px; flex-wrap:wrap;">
          <a href="/admin/menu/master" class="btn btn-sm <%= isMaster ? 'btn-primary' : 'btn-secondary' %>">📚 Master Menu</a>
          <a href="/admin/menu/template" class="btn btn-sm <%= isTemplate ? 'btn-primary' : 'btn-secondary' %>">📅 Template Hari</a>
          <a href="/admin/menu/makanan" class="btn btn-sm <%= isMakanan ? 'btn-primary' : 'btn-secondary' %>">🍱 Menu Makanan</a>
          <a href="/admin/menu/jadwal" class="btn btn-sm <%= isJadwal ? 'btn-primary' : 'btn-secondary' %>">👨‍🍳 Jadwal Petugas</a>
          <a href="/admin/menu/distribusi" class="btn btn-sm <%= isDistribusi ? 'btn-primary' : 'btn-secondary' %>">📦 Distribusi</a>
          <a href="/admin/menu/permintaan" class="btn btn-sm <%= isPermintaan ? 'btn-primary' : 'btn-secondary' %>">📄 Permintaan</a>
          <a href="/admin/menu/diterima" class="btn btn-sm <%= isDiterima ? 'btn-primary' : 'btn-secondary' %>">📥 Diterima</a>
          <a href="/admin/menu/penyimpanan" class="btn btn-sm <%= isPenyimpanan ? 'btn-primary' : 'btn-secondary' %>">🏪 Penyimpanan</a>
        </div>
      </div>

      <% if (isPermintaan) { %>
      <div class="card">
        <div class="card-header"><h3>📄 Daftar Permintaan Bahan Makanan</h3></div>
        <div class="card-body">
          <form method="GET" action="/admin/menu/permintaan" style="display:flex; gap:10px; flex-wrap:wrap; align-items:end; margin-bottom:12px;">
            <div class="form-group" style="min-width: 220px; margin:0;">
              <label>Tanggal</label>
              <input type="date" name="tanggal_bama" value="<%= selectedBamaDate || todayYmd %>">
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button type="submit" class="btn btn-primary btn-sm">🔎 Tampilkan</button>
              <a href="/admin/menu/permintaan" class="btn btn-secondary btn-sm">↺ Hari ini</a>
            </div>
          </form>

          <form method="POST" action="/admin/menu/permintaan/save">
            <input type="hidden" name="tanggal_bama" value="<%= selectedBamaDate || todayYmd %>">

            <div style="margin-bottom:10px; font-size:12px; color:#475569; font-weight:700;">
              Tanggal: <%= formatDateIndo(selectedBamaDate || todayYmd) %> | Template Menu Harian: <%= selectedBamaMenuHari || 'BELUM DISET' %>
            </div>

            <div class="table-wrap">
              <table class="admin-table">
                <thead><tr><th>No</th><th>Jenis Bahan Makanan</th><th>Berat Kotor</th><th>Satuan</th><th>Banyaknya</th><th>Keterangan</th></tr></thead>
                <tbody>
                  <% bamaMasterList.forEach((item, i) => { const value = bamaPermintaanById?.[item.id] || {}; %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td style="text-align:left;"><strong><%= item.namaBahan || '-' %></strong></td>
                    <td><input type="text" name="berat_kotor_<%= item.id %>" value="<%= value.beratKotor || '' %>" placeholder="0,0000"></td>
                    <td><input type="text" name="satuan_<%= item.id %>" value="<%= value.satuan || item.satuanDefault || 'Kg' %>"></td>
                    <td><input type="text" name="banyaknya_<%= item.id %>" value="<%= value.banyaknya || '' %>" placeholder="0,0000"></td>
                    <td><input type="text" name="keterangan_<%= item.id %>" value="<%= value.keterangan || '' %>" placeholder="Opsional"></td>
                  </tr>
                  <% }) %>
                  <% if (!bamaMasterList.length) { %><tr><td colspan="6" style="text-align:center;color:#aaa;padding:20px;">Belum ada master bahan makanan</td></tr><% } %>
                </tbody>
              </table>
            </div>
            <div style="display:flex; gap:8px; align-items:center; margin-top:12px;">
              <button type="submit" class="btn btn-primary btn-sm" <%= !bamaMasterList.length ? 'disabled' : '' %>>💾 Simpan Permintaan</button>
            </div>
          </form>
        </div>
      </div>
      <% } %>

      <% if (isDiterima) { %>
      <div class="card">
        <div class="card-header"><h3>📥 Berita Acara Penerimaan Bahan Makanan</h3></div>
        <div class="card-body">
          <form method="GET" action="/admin/menu/diterima" style="display:flex; gap:10px; flex-wrap:wrap; align-items:end; margin-bottom:12px;">
            <div class="form-group" style="min-width: 220px; margin:0;">
              <label>Tanggal</label>
              <input type="date" name="tanggal_bama" value="<%= selectedBamaDate || todayYmd %>">
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button type="submit" class="btn btn-primary btn-sm">🔎 Tampilkan</button>
              <a href="/admin/menu/diterima" class="btn btn-secondary btn-sm">↺ Hari ini</a>
            </div>
          </form>

          <form method="POST" action="/admin/menu/diterima/save">
            <input type="hidden" name="tanggal_bama" value="<%= selectedBamaDate || todayYmd %>">

            <div style="margin-bottom:10px; font-size:12px; color:#475569; font-weight:700;">
              Tanggal: <%= formatDateIndo(selectedBamaDate || todayYmd) %> | Template Menu Harian: <%= selectedBamaMenuHari || 'BELUM DISET' %>
            </div>

            <div class="table-wrap">
              <table class="admin-table">
                <thead><tr><th>No</th><th>Jenis BAMA</th><th>Satuan</th><th>Jumlah Permintaan BAMA</th><th>Jumlah BAMA yang Diterima</th><th>Keterangan</th></tr></thead>
                <tbody>
                  <% bamaMasterList.forEach((item, i) => { const value = bamaDiterimaById?.[item.id] || {}; %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td style="text-align:left;"><strong><%= item.namaBahan || '-' %></strong></td>
                    <td><input type="text" name="satuan_<%= item.id %>" value="<%= value.satuan || item.satuanDefault || 'Kg' %>"></td>
                    <td><input type="text" name="jumlah_permintaan_<%= item.id %>" value="<%= value.jumlahPermintaan || '' %>" placeholder="0,0000"></td>
                    <td><input type="text" name="jumlah_diterima_<%= item.id %>" value="<%= value.jumlahDiterima || '' %>" placeholder="0,0000"></td>
                    <td><input type="text" name="keterangan_<%= item.id %>" value="<%= value.keterangan || '' %>" placeholder="Opsional"></td>
                  </tr>
                  <% }) %>
                  <% if (!bamaMasterList.length) { %><tr><td colspan="6" style="text-align:center;color:#aaa;padding:20px;">Belum ada master bahan makanan</td></tr><% } %>
                </tbody>
              </table>
            </div>
            <div style="display:flex; gap:8px; align-items:center; margin-top:12px;">
              <button type="submit" class="btn btn-primary btn-sm" <%= !bamaMasterList.length ? 'disabled' : '' %>>💾 Simpan Data Diterima</button>
            </div>
          </form>
        </div>
      </div>
      <% } %>

      <% if (isPenyimpanan) { %>
      <div class="card">
        <div class="card-header"><h3>🏪 Daftar Penyimpanan Bahan Makanan</h3></div>
        <div class="card-body">
          <form method="GET" action="/admin/menu/penyimpanan" style="display:flex; gap:10px; flex-wrap:wrap; align-items:end; margin-bottom:12px;">
            <div class="form-group" style="min-width: 220px; margin:0;">
              <label>Tanggal</label>
              <input type="date" name="tanggal_bama" value="<%= selectedBamaDate || todayYmd %>">
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button type="submit" class="btn btn-primary btn-sm">🔎 Tampilkan</button>
              <a href="/admin/menu/penyimpanan" class="btn btn-secondary btn-sm">↺ Hari ini</a>
            </div>
          </form>

          <form method="POST" action="/admin/menu/penyimpanan/save">
            <input type="hidden" name="tanggal_bama" value="<%= selectedBamaDate || todayYmd %>">

            <div style="margin-bottom:10px; font-size:12px; color:#475569; font-weight:700;">
              Tanggal: <%= formatDateIndo(selectedBamaDate || todayYmd) %> | Template Menu Harian: <%= selectedBamaMenuHari || 'BELUM DISET' %>
            </div>

            <div class="table-wrap">
              <table class="admin-table">
                <thead><tr><th>No</th><th>Nama Barang</th><th>Satuan</th><th>Barang Masuk</th><th>Barang Keluar</th><th>Barang Sisa</th><th>Keterangan</th></tr></thead>
                <tbody>
                  <% bamaMasterList.forEach((item, i) => { const value = bamaPenyimpananById?.[item.id] || {}; %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td style="text-align:left;"><strong><%= item.namaBahan || '-' %></strong></td>
                    <td><input type="text" name="satuan_<%= item.id %>" value="<%= value.satuan || item.satuanDefault || 'Kg' %>"></td>
                    <td><input type="text" name="barang_masuk_<%= item.id %>" value="<%= value.barangMasuk || '' %>" placeholder="0,0000"></td>
                    <td><input type="text" name="barang_keluar_<%= item.id %>" value="<%= value.barangKeluar || '' %>" placeholder="0,0000"></td>
                    <td><input type="text" name="barang_sisa_<%= item.id %>" value="<%= value.barangSisa || '' %>" placeholder="0,0000"></td>
                    <td><input type="text" name="keterangan_<%= item.id %>" value="<%= value.keterangan || '' %>" placeholder="Opsional"></td>
                  </tr>
                  <% }) %>
                  <% if (!bamaMasterList.length) { %><tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada master bahan makanan</td></tr><% } %>
                </tbody>
              </table>
            </div>
            <div style="display:flex; gap:8px; align-items:center; margin-top:12px;">
              <button type="submit" class="btn btn-primary btn-sm" <%= !bamaMasterList.length ? 'disabled' : '' %>>💾 Simpan Penyimpanan</button>
            </div>
          </form>
        </div>
      </div>
      <% } %>

      <% if (isDistribusi) { %>
      <div class="card" id="template-distribusi-card">
        <div class="card-header"><h3>🏢 Template Blok Distribusi</h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editDistribusiBlok ? `/admin/menu/distribusi/blok/${editDistribusiBlok.id}/update` : '/admin/menu/distribusi/blok/add' %>">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Nama Blok</label>
                <input type="text" name="nama_blok" value="<%= editDistribusiBlok ? (editDistribusiBlok.namaBlok || '') : '' %>" placeholder="Contoh: Mawar T3 Lt.1.1" required>
              </div>
              <div class="form-group">
                <label>Urutan</label>
                <input type="number" min="1" name="sort_order" value="<%= editDistribusiBlok ? (editDistribusiBlok.sortOrder || '') : '' %>" placeholder="Contoh: 1">
              </div>
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button type="submit" class="btn btn-primary btn-sm"><%= editDistribusiBlok ? '💾 Simpan Template' : '➕ Tambah Template Blok' %></button>
              <% if (editDistribusiBlok) { %>
                <a href="/admin/menu/distribusi#template-distribusi-card" class="btn btn-secondary btn-sm">✕ Batal Edit</a>
              <% } %>
            </div>
          </form>

          <div class="table-wrap" style="margin-top:14px;">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Nama Blok</th><th>Urutan</th><th>Status</th><th>Aksi</th></tr></thead>
              <tbody>
                <% distribusiBlokAllList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.namaBlok || '-' %></td>
                  <td><%= item.sortOrder || '-' %></td>
                  <td><%= Number(item.isActive) === 1 ? 'Aktif' : 'Nonaktif' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/menu/distribusi?editDistribusiBlok=<%= item.id %>#template-distribusi-card" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <% if (Number(item.isActive) === 1) { %>
                      <form method="POST" action="/admin/menu/distribusi/blok/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Nonaktifkan template blok ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Nonaktifkan</button>
                      </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!distribusiBlokAllList.length) { %><tr><td colspan="5" style="text-align:center;color:#aaa;padding:20px;">Belum ada template blok</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card" id="entri-distribusi-card">
        <div class="card-header"><h3>📝 Entri Distribusi Makanan (3x per hari)</h3></div>
        <div class="card-body">
          <form method="GET" action="/admin/menu/distribusi" style="display:flex; gap:10px; flex-wrap:wrap; align-items:end; margin-bottom:12px;">
            <div class="form-group" style="min-width: 220px; margin:0;">
              <label>Tanggal entri</label>
              <input type="date" name="tanggal_distribusi" value="<%= selectedDistribusiDate || todayYmd %>">
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button type="submit" class="btn btn-primary btn-sm">🔎 Tampilkan</button>
              <a href="/admin/menu/distribusi" class="btn btn-secondary btn-sm">↺ Hari ini</a>
            </div>
          </form>

          <form method="POST" action="/admin/menu/distribusi/entry/save">
            <input type="hidden" name="tanggal_distribusi" value="<%= selectedDistribusiDate || todayYmd %>">

            <div style="margin-bottom:10px; font-size:12px; color:#475569; font-weight:700;">
              Tanggal aktif: <%= formatDateIndo(selectedDistribusiDate || todayYmd) %> | Header sesi: Pagi (08:00), Siang (12:00), Sore (16:00) | Total tanggal entri tersimpan: <%= totalDistribusiHistory %>
            </div>

            <div class="table-wrap">
              <table class="admin-table">
                <thead><tr><th>#</th><th>Nama Blok</th><th>Pagi (08:00)</th><th>Siang (12:00)</th><th>Sore (16:00)</th></tr></thead>
                <tbody>
                  <% distribusiBlokList.forEach((blok, i) => { %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td><strong><%= blok.namaBlok || '-' %></strong></td>
                    <td>
                      <input type="number" min="0" name="jumlah_pagi_<%= blok.id %>" value="<%= Number(distribusiByBlokJam?.[blok.id]?.['08:00'] ?? 0) %>" style="max-width:140px;">
                    </td>
                    <td>
                      <input type="number" min="0" name="jumlah_siang_<%= blok.id %>" value="<%= Number(distribusiByBlokJam?.[blok.id]?.['12:00'] ?? 0) %>" style="max-width:140px;">
                    </td>
                    <td>
                      <input type="number" min="0" name="jumlah_sore_<%= blok.id %>" value="<%= Number(distribusiByBlokJam?.[blok.id]?.['16:00'] ?? 0) %>" style="max-width:140px;">
                    </td>
                  </tr>
                  <% }) %>
                  <% if (!distribusiBlokList.length) { %><tr><td colspan="5" style="text-align:center;color:#aaa;padding:20px;">Belum ada template blok aktif</td></tr><% } %>
                </tbody>
              </table>
            </div>

            <div style="display:flex; gap:8px; align-items:center; margin-top:12px;">
              <button type="submit" class="btn btn-primary btn-sm" <%= !distribusiBlokList.length ? 'disabled' : '' %>>💾 Simpan Entri Sesi</button>
            </div>
          </form>

          <div style="margin-top:12px; display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
            <% distribusiStatusPerJam.forEach((item) => { %>
              <span style="display:inline-flex; align-items:center; gap:6px; border:1px solid <%= item.complete ? '#86efac' : '#fca5a5' %>; background:<%= item.complete ? '#f0fdf4' : '#fef2f2' %>; color:<%= item.complete ? '#166534' : '#991b1b' %>; border-radius:999px; padding:4px 10px; font-size:12px; font-weight:800;">
                Jam <%= item.jam %> <%= item.complete ? '✓ Lengkap' : '• Belum Lengkap' %>
              </span>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>

      <% if (isJadwal) { %>
      <div class="card" id="petugas-dapur-card">
        <div class="card-header"><h3>👥 Data Petugas Dapur</h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editPetugas ? `/admin/menu/petugas/${editPetugas.id}/update` : '/admin/menu/petugas/add' %>">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>NIP</label>
                <input type="text" name="nip" value="<%= editPetugas ? (editPetugas.nip || '') : '' %>" required>
              </div>
              <div class="form-group">
                <label>Nama</label>
                <input type="text" name="nama" value="<%= editPetugas ? (editPetugas.nama || '') : '' %>" required>
              </div>
              <div class="form-group">
                <label>Jabatan</label>
                <input type="text" name="jabatan" value="<%= editPetugas ? (editPetugas.jabatan || '') : '' %>" required>
              </div>
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button type="submit" class="btn btn-primary btn-sm"><%= editPetugas ? '💾 Simpan Petugas' : '➕ Tambah Petugas' %></button>
              <% if (editPetugas) { %>
                <a href="/admin/menu/jadwal#petugas-dapur-card" class="btn btn-secondary btn-sm">✕ Batal Edit Petugas</a>
              <% } %>
            </div>
          </form>

          <div class="table-wrap" style="margin-top:14px;">
            <table class="admin-table">
              <thead><tr><th>#</th><th>NIP</th><th>Nama</th><th>Jabatan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% dapurPetugasList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.nip || '-' %></td>
                  <td><%= item.nama || '-' %></td>
                  <td><%= item.jabatan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/menu/jadwal?editPetugas=<%= item.id %>#petugas-dapur-card" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/menu/petugas/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus petugas ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!dapurPetugasList.length) { %><tr><td colspan="5" style="text-align:center;color:#aaa;padding:20px;">Belum ada data petugas</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card" id="jadwal-petugas-card">
        <div class="card-header"><h3>🗓 Jadwal Petugas Dapur / Hari</h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editJadwal ? `/admin/menu/jadwal/${editJadwal.id}/update` : '/admin/menu/jadwal/add' %>">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Tanggal</label>
                <input type="date" name="tanggal" value="<%= editJadwal ? (editJadwal.tanggal || selectedJadwalDate || todayYmd) : (selectedJadwalDate || todayYmd) %>" required>
              </div>
              <div class="form-group">
                <label>Pilih Petugas</label>
                <select name="petugas_id" required>
                  <option value="">-- Pilih petugas --</option>
                  <% dapurPetugasList.forEach((petugas) => { %>
                    <option value="<%= petugas.id %>" <%= Number(editJadwal?.petugasId || 0) === Number(petugas.id) ? 'selected' : '' %>><%= `${petugas.nip} | ${petugas.nama} | ${petugas.jabatan}` %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group" style="grid-column: span 3;">
                <label>Deskripsi Tugas</label>
                <textarea name="deskripsi_tugas" rows="3" placeholder="Contoh: Menyiapkan sarapan blok A dan distribusi snack pagi" required><%= editJadwal ? (editJadwal.deskripsiTugas || '') : '' %></textarea>
              </div>
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button type="submit" class="btn btn-primary btn-sm" <%= !dapurPetugasList.length ? 'disabled' : '' %>><%= editJadwal ? '💾 Simpan Jadwal' : '➕ Tambah Jadwal' %></button>
              <% if (editJadwal) { %>
                <a href="/admin/menu/jadwal?tanggal_jadwal=<%= encodeURIComponent(selectedJadwalDate || todayYmd) %>#jadwal-petugas-card" class="btn btn-secondary btn-sm">✕ Batal Edit Jadwal</a>
              <% } %>
            </div>
            <% if (!dapurPetugasList.length) { %>
              <div style="margin-top:8px; font-size:12px; color:#b91c1c; font-weight:700;">Tambahkan data petugas terlebih dahulu sebelum membuat jadwal.</div>
            <% } %>
          </form>

          <div style="margin-top:10px; display:flex; gap:12px; align-items:end; justify-content:space-between; flex-wrap:wrap;">
            <div style="font-size:12px; color:#64748b; font-weight:700;">
              Tanggal aktif: <%= formatDateIndo(selectedJadwalDate || todayYmd) %> | Total tanggal jadwal tersimpan: <%= totalJadwalHistory %>
            </div>
            <form method="GET" action="/admin/menu/jadwal" style="display:flex; gap:10px; flex-wrap:wrap; align-items:end; justify-content:flex-end;">
              <div class="form-group" style="min-width: 220px; margin:0;">
                <label>Tanggal jadwal</label>
                <input type="date" name="tanggal_jadwal" value="<%= selectedJadwalDate || todayYmd %>">
              </div>
              <div style="display:flex; gap:8px; align-items:center;">
                <button type="submit" class="btn btn-primary btn-sm">🔎 Tampilkan</button>
                <a href="/admin/menu/jadwal" class="btn btn-secondary btn-sm">↺ Hari ini</a>
              </div>
            </form>
          </div>

          <div class="table-wrap" style="margin-top:14px;">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Tanggal</th><th>NIP</th><th>Nama</th><th>Jabatan</th><th>Deskripsi Tugas</th><th>Aksi</th></tr></thead>
              <tbody>
                <% jadwalPetugasList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= formatDateIndo(item.tanggal || '-') %></td>
                  <td><%= item.nip || '-' %></td>
                  <td><%= item.nama || '-' %></td>
                  <td><%= item.jabatan || '-' %></td>
                  <td style="white-space:pre-line;"><%= item.deskripsiTugas || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/menu/jadwal?tanggal_jadwal=<%= encodeURIComponent(selectedJadwalDate || todayYmd) %>&editJadwal=<%= item.id %>#jadwal-petugas-card" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/menu/jadwal/<%= item.id %>/delete?tanggal_jadwal=<%= encodeURIComponent(selectedJadwalDate || todayYmd) %>" style="display:inline" onsubmit="return confirm('Hapus jadwal ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!jadwalPetugasList.length) { %><tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada jadwal pada tanggal ini</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>

      <% if (isMakanan) { %>
      <div class="card">
        <div class="card-header"><h3>📝 Judul Menu (Publik)</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/menu/title/update">
            <div class="form-group" style="margin-bottom:12px;">
              <label>Judul Panel Menu</label>
              <input type="text" name="menu_title" value="<%= menuTitle %>" placeholder="Contoh: DAFTAR MENU MAKAN HARI INI" required>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">💾 Simpan Judul</button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>🗓 Set Menu Harian (Tanggal + List Hari)</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/menu/harian/set">
            <div class="form-group" style="max-width:240px; margin-bottom:10px;">
              <label>Tanggal set menu</label>
              <input type="date" name="tanggal" value="<%= selectedTanggal || todayYmd %>" required>
            </div>
            <div style="margin-top:10px; font-size:12px; color:#64748b; font-weight:700; margin-bottom:10px;">
              Tanggal aktif: <%= formatDateIndo(selectedTanggal || todayYmd) %> | Total tanggal tersimpan: <%= totalHistory %>
              <% if (selectedSet) { %> | List aktif: <%= selectedSet.namaList %><% } %>
            </div>
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:10px; margin-bottom:12px;">
              <% dayLists.forEach((item) => { %>
              <label style="display:flex; gap:10px; align-items:flex-start; border:1px solid #dbe3f1; border-radius:10px; padding:10px; cursor:pointer;">
                <input type="radio" name="list_id" value="<%= item.id %>" <%= Number(selectedListId || 0) === Number(item.id) ? 'checked' : '' %> style="margin-top:3px;">
                <div>
                  <div style="font-weight:800; font-size:12px; color:#334155;"><%= item.namaList %></div>
                  <div style="font-size:12px; color:#64748b;"><%= item.totalItem %> menu</div>
                </div>
              </label>
              <% }) %>
            </div>
            <% if (!dayLists.length) { %>
            <div style="font-size:13px; color:#9ca3af; margin-bottom:12px;">Belum ada list hari. Buat dulu di bagian List Hari.</div>
            <% } %>
            <button type="submit" class="btn btn-primary btn-sm" <%= !dayLists.length ? 'disabled' : '' %>>💾 Set Menu Harian</button>
          </form>
        </div>
      </div>
      <% } %>

      <% if (isMakanan) { %>
      <div class="card" id="menu-preview-card">
        <div class="card-header">
          <div style="display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap; align-items:end; width:100%;">
            <div>
              <h3>
                <%= `Preview Menu Tanggal ${formatDateIndo(selectedTanggal || todayYmd)}` %>
                (<%= dailyList.length %> item)
              </h3>
            </div>
            <form method="GET" action="/admin/menu/makanan" style="display:flex; gap:10px; flex-wrap:wrap; align-items:end; justify-content:flex-end;">
              <div class="form-group" style="min-width: 220px; margin:0;">
                <label>Tanggal tampil</label>
                <input type="date" name="tanggal" value="<%= selectedTanggal || todayYmd %>">
              </div>
              <div style="display:flex; gap:8px; align-items:center;">
                <button type="submit" class="btn btn-primary btn-sm">🔎 Tampilkan</button>
                <a href="/admin/menu/makanan" class="btn btn-secondary btn-sm">↺ Hari ini</a>
              </div>
            </form>
          </div>
        </div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Tanggal</th><th>Foto</th><th>Waktu</th><th>Menu</th></tr></thead>
              <tbody>
                <% dailyList.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= formatDateIndo(item.tanggal) %></td>
                  <td>
                    <% if (item.photo_path) { %>
                      <img src="<%= item.photo_path %>" alt="Foto menu" class="admin-menu-photo-thumb">
                    <% } else { %>
                      <span style="color:#aaa;">-</span>
                    <% } %>
                  </td>
                  <td><strong><%= item.waktu %></strong></td>
                  <td><%= item.menu %></td>
                </tr>
                <% }) %>
                <% if (!dailyList.length) { %><tr><td colspan="5" style="text-align:center;color:#aaa;padding:20px;">Belum ada data pada tanggal ini</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>

      <% if (isTemplate) { %>
      <div class="card" id="list-hari-card">
        <div class="card-header"><h3>📅 List Hari (Template Harian)</h3></div>
        <div class="card-body">
          <form method="POST" action="<%= editDayList ? `/admin/menu/list/${editDayList.id}/update` : '/admin/menu/list/add' %>">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Nama List Hari</label>
                <input type="text" id="nama-list-hari" name="nama_list" placeholder="Contoh: Hari Ke-1" value="<%= editDayList ? editDayList.namaList : '' %>" required>
              </div>
            </div>
            <label style="display:block; font-weight:700; margin-bottom:8px;">Isi Menu dalam List Hari</label>
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap:10px; margin-bottom:12px;">
              <% masterList.forEach((item) => { %>
              <label style="display:flex; gap:10px; align-items:flex-start; border:1px solid #dbe3f1; border-radius:10px; padding:10px; cursor:pointer;">
                <input type="checkbox" name="menu_ids" value="<%= item.id %>" <%= selectedMasterIds.includes(item.id) ? 'checked' : '' %> style="margin-top:3px;">
                <div>
                  <div style="font-weight:800; font-size:12px; color:#334155;"><%= item.waktu %></div>
                  <div style="font-size:13px; color:#0f172a;"><%= item.menu %></div>
                </div>
              </label>
              <% }) %>
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button type="submit" class="btn btn-primary btn-sm" <%= !masterList.length ? 'disabled' : '' %>><%= editDayList ? '💾 Simpan Perubahan List' : '➕ Tambah List Hari' %></button>
              <% if (editDayList) { %>
              <a href="/admin/menu/template?tanggal=<%= selectedTanggal || todayYmd %>" class="btn btn-secondary btn-sm">✕ Batal Edit List</a>
              <% } %>
            </div>
          </form>

          <div class="table-wrap" style="margin-top:14px;">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Nama List</th><th>Total Menu</th><th>Aksi</th></tr></thead>
              <tbody>
                <% dayLists.forEach((item, i) => { %>
                <tr data-list-id="<%= item.id %>">
                  <td><%= i + 1 %></td>
                  <td><strong><%= item.namaList %></strong></td>
                  <td><%= item.totalItem %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/menu/template?tanggal=<%= selectedTanggal || todayYmd %>&editList=<%= item.id %>#list-hari-card" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <a href="/admin/menu/template?tanggal=<%= selectedTanggal || todayYmd %>&previewList=<%= item.id %>#menu-preview-card" class="btn btn-info btn-xs">👁 Preview</a>
                      <form method="POST" action="/admin/menu/list/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus list hari ini?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!dayLists.length) { %><tr><td colspan="4" style="text-align:center;color:#aaa;padding:20px;">Belum ada list hari</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card" id="menu-preview-card">
        <div class="card-header">
          <h3>
            <%= `Preview Template ${dayLists.find(item => Number(item.id) === Number(selectedListId || 0))?.namaList || '-'}` %>
            (<%= dailyList.length %> item)
          </h3>
        </div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Foto</th><th>Waktu</th><th>Menu</th></tr></thead>
              <tbody>
                <% dailyList.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td>
                    <% if (item.photo_path) { %>
                      <img src="<%= item.photo_path %>" alt="Foto menu" class="admin-menu-photo-thumb">
                    <% } else { %>
                      <span style="color:#aaa;">-</span>
                    <% } %>
                  </td>
                  <td><strong><%= item.waktu %></strong></td>
                  <td><%= item.menu %></td>
                </tr>
                <% }) %>
                <% if (!dailyList.length) { %><tr><td colspan="4" style="text-align:center;color:#aaa;padding:20px;">Belum ada data template ini</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>

      <% if (isMaster) { %>
      <div class="card">
        <div class="card-header"><h3>📚 Master List Menu</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/menu/add" enctype="multipart/form-data">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Waktu Makan</label>
                <select name="waktu" required>
                  <option value="">-- Pilih --</option>
                  <option value="MAKAN PAGI">MAKAN PAGI</option>
                  <option value="SNACK">SNACK</option>
                  <option value="MAKAN SIANG">MAKAN SIANG</option>
                  <option value="MAKAN SORE">MAKAN SORE</option>
                </select>
              </div>
              <div class="form-group">
                <label>Deskripsi Menu</label>
                <input type="text" name="menu" placeholder="Contoh: Nasi Putih, Ayam Kecap" required>
              </div>
              <div class="form-group">
                <label>Foto Menu (opsional)</label>
                <input type="file" name="photo" accept="image/*">
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah ke Master</button>
          </form>
        </div>
      </div>

      <% if (editMaster) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Master Menu (ID: <%= editMaster.id %>)</h4>
        <form method="POST" action="/admin/menu/<%= editMaster.id %>/update" enctype="multipart/form-data">
          <div class="form-grid col-3" style="margin-bottom:12px;">
            <div class="form-group">
              <label>Waktu Makan</label>
              <select name="waktu" required>
                <% ['MAKAN PAGI','SNACK','MAKAN SIANG','MAKAN SORE'].forEach(w => { %>
                <option value="<%= w %>" <%= editMaster.waktu===w?'selected':'' %>><%= w %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>Menu</label>
              <input type="text" name="menu" value="<%= editMaster.menu %>" required>
            </div>
            <div class="form-group full">
              <label>Foto Menu (opsional, upload untuk mengganti)</label>
              <input type="file" name="photo" accept="image/*">
            </div>
            <% if (editMaster.photo_path) { %>
            <div class="form-group full">
              <label>Foto Saat Ini</label>
              <img src="<%= editMaster.photo_path %>" alt="Foto menu" class="admin-menu-photo-preview">
            </div>
            <% } %>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/menu/master" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Master Menu (<%= masterList.length %> item)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Foto</th><th>Waktu</th><th>Menu</th><th>Template Hari</th><th>Aksi</th></tr></thead>
              <tbody>
                <% masterList.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td>
                    <% if (item.photo_path) { %>
                      <img src="<%= item.photo_path %>" alt="Foto menu" class="admin-menu-photo-thumb">
                    <% } else { %>
                      <span style="color:#aaa;">-</span>
                    <% } %>
                  </td>
                  <td><strong><%= item.waktu %></strong></td>
                  <td><%= item.menu %></td>
                  <td><%= item.templateHari || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/menu/master?editMaster=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/menu/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!masterList.length) { %><tr><td colspan="6" style="text-align:center;color:#aaa;padding:20px;">Belum ada master menu</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
<script>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const editListId = params.get('editList');
    const previewListId = params.get('previewList');

    const flashTarget = (target) => {
      if (!target) return;
      const originalTransition = target.style.transition;
      const originalOutline = target.style.outline;
      const originalOutlineOffset = target.style.outlineOffset;
      target.style.transition = 'outline-color 0.2s ease';
      target.style.outline = '2px solid #2563eb';
      target.style.outlineOffset = '2px';
      setTimeout(() => {
        target.style.outline = originalOutline;
        target.style.outlineOffset = originalOutlineOffset;
        target.style.transition = originalTransition;
      }, 1400);
    };

    if (editListId) {
      const section = document.getElementById('list-hari-card');
      const input = document.getElementById('nama-list-hari');
      section && section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      setTimeout(() => {
        if (input) {
          input.focus();
          input.select();
        }
      }, 220);
      flashTarget(section);
    }

    if (previewListId) {
      const previewCard = document.getElementById('menu-preview-card');
      const activeRow = document.querySelector(`tr[data-list-id="${previewListId}"]`);
      previewCard && previewCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      flashTarget(previewCard);
      flashTarget(activeRow);
    }
  })();
</script>
</body>
</html>
