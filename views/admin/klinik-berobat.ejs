<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WBP Berobat – Admin Klinik</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .berobat-filter-split {
      display: flex;
      gap: 40px;
      align-items: end;
      justify-content: space-between;
      flex-wrap: nowrap;
    }
    .berobat-filter-search {
      display: flex;
      gap: 8px;
      align-items: end;
      flex: 0 1 58%;
      max-width: 760px;
      min-width: 360px;
      flex-wrap: nowrap;
    }
    .berobat-filter-search .form-group {
      flex: 1;
      max-width: 520px;
      min-width: 280px;
    }
    .berobat-filter-date {
      display: flex;
      gap: 8px;
      align-items: end;
      flex: 0 0 auto;
      justify-content: flex-end;
      flex-wrap: nowrap;
    }
    @media (max-width: 1180px) {
      .berobat-filter-split { gap: 18px; }
      .berobat-filter-search { flex-basis: 52%; min-width: 320px; }
      .berobat-filter-search .form-group { max-width: 450px; }
    }
    @media (max-width: 980px) {
      .berobat-filter-split { flex-wrap: wrap; }
      .berobat-filter-search,
      .berobat-filter-date {
        flex: 1 1 100%;
        min-width: 0;
        max-width: 100%;
        justify-content: flex-start;
      }
      .berobat-filter-search .form-group { max-width: 100%; }
    }
  </style>
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>🏥 WBP Berobat</h2><p>Kelola data WBP yang berobat</p></div>
      <div class="topbar-actions"><a href="/klinik" target="_blank" class="btn-public">🌐 Lihat Klinik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>

      <div class="card">
        <div class="card-header"><h3>➕ Tambah Data WBP Berobat</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/klinik-berobat/add<%= filterQuery %>">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>No. Registrasi</label>
                <input type="text" name="no_reg" placeholder="cth: BI.150-A/2023" required>
              </div>
              <div class="form-group">
                <label>Nama WBP</label>
                <input type="text" name="nama_wbp" placeholder="Nama lengkap" required>
              </div>
              <div class="form-group">
                <label>Layanan</label>
                <input type="text" name="layanan" placeholder="cth: Poliklinik" required>
              </div>
              <div class="form-group">
                <label>Diagnosa</label>
                <input type="text" name="diagnosa" placeholder="cth: ISPA, TB Paru" required>
              </div>
              <div class="form-group">
                <label>Blok</label>
                <input type="text" name="blok" placeholder="cth: Blok A1" required>
              </div>
              <div class="form-group">
                <label>Status Perawatan</label>
                <select name="status_perawatan" required>
                  <option value="Rawat Jalan">Rawat Jalan</option>
                  <option value="Rawat Inap">Rawat Inap</option>
                  <option value="Selesai">Selesai</option>
                </select>
              </div>
              <div class="form-group">
                <label>Tanggal</label>
                <input type="date" name="tanggal" value="<%= selectedTanggal || todayYmd %>" required>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah</button>
          </form>
        </div>
      </div>

      <% if (edit) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Data WBP Berobat (ID: <%= edit.id %>)</h4>
        <form method="POST" action="/admin/klinik-berobat/<%= edit.id %>/update<%= filterQuery %>">
          <div class="form-grid col-3" style="margin-bottom:12px;">
            <div class="form-group">
              <label>No. Registrasi</label>
              <input type="text" name="no_reg" value="<%= edit.no_reg %>" required>
            </div>
            <div class="form-group">
              <label>Nama WBP</label>
              <input type="text" name="nama_wbp" value="<%= edit.nama_wbp %>" required>
            </div>
            <div class="form-group">
              <label>Layanan</label>
              <input type="text" name="layanan" value="<%= edit.layanan %>" required>
            </div>
            <div class="form-group">
              <label>Diagnosa</label>
              <input type="text" name="diagnosa" value="<%= edit.diagnosa %>" required>
            </div>
            <div class="form-group">
              <label>Blok</label>
              <input type="text" name="blok" value="<%= edit.blok %>" required>
            </div>
            <div class="form-group">
              <label>Status Perawatan</label>
              <select name="status_perawatan" required>
                <option value="Rawat Jalan" <%= edit.status_perawatan==='Rawat Jalan'?'selected':'' %>>Rawat Jalan</option>
                <option value="Rawat Inap" <%= edit.status_perawatan==='Rawat Inap'?'selected':'' %>>Rawat Inap</option>
                <option value="Selesai" <%= edit.status_perawatan==='Selesai'?'selected':'' %>>Selesai</option>
              </select>
            </div>
            <div class="form-group">
              <label>Tanggal</label>
              <input type="date" name="tanggal" value="<%= edit.tanggal || selectedTanggal || todayYmd %>" required>
            </div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/klinik-berobat<%= filterQuery %>" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header">
          <h3>
            <% if (searchKeyword) { %>
              Hasil Pencarian WBP Berobat (<%= list.length %> data) - Seluruh Riwayat
            <% } else { %>
              Daftar WBP Berobat (<%= list.length %> data) - <%= formatDateIndo(selectedTanggal || todayYmd) %>
            <% } %>
          </h3>
        </div>
        <div class="card-body" style="padding:0;">
          <div style="padding:12px 12px 0;">
            <div class="berobat-filter-split">
              <form method="GET" action="/admin/klinik-berobat" class="berobat-filter-search">
                <input type="hidden" name="tanggal" value="<%= selectedTanggal || todayYmd %>">
                <div class="form-group" style="margin:0;">
                  <label>Pencarian Riwayat (Lintas Tanggal)</label>
                  <input type="text" name="search" value="<%= searchKeyword || '' %>" placeholder="Cari nama, no reg, diagnosa, blok, status, tanggal">
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Terapkan</button>
              </form>
              <form method="GET" action="/admin/klinik-berobat" class="berobat-filter-date">
                <div class="form-group" style="min-width: 220px; margin:0;">
                  <label>Filter Tanggal WBP Berobat</label>
                  <input type="date" name="tanggal" value="<%= selectedTanggal || todayYmd %>">
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Terapkan</button>
                <a href="/admin/klinik-berobat" class="btn btn-secondary btn-sm">↺ Hari ini</a>
              </form>
            </div>
            <div style="margin-top:8px; font-size:12px; color:#64748b; font-weight:700;">
              Tanggal aktif: <%= formatDateIndo(selectedTanggal || todayYmd) %> | Total history tersimpan: <%= totalHistory %>
              <% if (searchKeyword) { %>
                <span style="color:#1e3a8a;">| Mode pencarian aktif: hasil tidak dibatasi tanggal</span>
              <% } %>
            </div>
          </div>
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr><th>#</th><th>No Reg</th><th>Nama WBP</th><th>Layanan</th><th>Diagnosa</th><th>Blok</th><th>Status</th><th>Tanggal</th><th>Aksi</th></tr>
              </thead>
              <tbody>
                <% list.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.no_reg %></td>
                  <td><%= item.nama_wbp %></td>
                  <td><%= item.layanan %></td>
                  <td><%= item.diagnosa %></td>
                  <td><%= item.blok %></td>
                  <td><%= item.status_perawatan %></td>
                  <td><%= formatDateIndo(item.tanggal) %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/klinik-berobat?edit=<%= item.id %><%= filterQueryWithAmp %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/klinik-berobat/<%= item.id %>/delete<%= filterQuery %>" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button type="submit" class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!list.length) { %>
                <tr><td colspan="9" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
