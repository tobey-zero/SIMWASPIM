<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pentahapan Pembinaan – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>👥 Pentahapan Pembinaan</h2><p>Kelola data WBP dan status integrasi</p></div>
      <div class="topbar-actions"><a href="/" target="_blank" class="btn-public">🌐 Lihat Publik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>

      <div class="card">
        <div class="card-header"><h3>➕ Tambah Data WBP</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/pembinaan/add">
            <div class="form-grid col-2" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Nama WBP</label>
                <input type="text" name="nama_wbp" placeholder="Nama lengkap WBP" required>
              </div>
              <div class="form-group">
                <label>Status Integrasi</label>
                <select name="status_integrasi" required>
                  <option value="">-- Pilih Status --</option>
                  <option value="-">-</option>
                  <option value="Menunggu SK">Menunggu SK</option>
                  <option value="Sudah dijatuhi Permintaan">Sudah dijatuhi Permintaan</option>
                  <option value="Sudah ada hasil SK">Sudah ada hasil SK</option>
                  <option value="Proses Sidang">Proses Sidang</option>
                  <option value="Ditolak">Ditolak</option>
                </select>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah</button>
          </form>
        </div>
      </div>

      <% if (edit) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Data WBP (ID: <%= edit.id %>)</h4>
        <form method="POST" action="/admin/pembinaan/<%= edit.id %>/update">
          <div class="form-grid col-2" style="margin-bottom:12px;">
            <div class="form-group">
              <label>Nama WBP</label>
              <input type="text" name="nama_wbp" value="<%= edit.nama_wbp %>" required>
            </div>
            <div class="form-group">
              <label>Status Integrasi</label>
              <select name="status_integrasi" required>
                <% ['-','Menunggu SK','Sudah dijatuhi Permintaan','Sudah ada hasil SK','Proses Sidang','Ditolak'].forEach(s => { %>
                <option value="<%= s %>" <%= edit.status_integrasi===s?'selected':'' %>><%= s %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/pembinaan" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar WBP (<%= list.length %> data)</h3><p>Ditampilkan berpasangan 2 kolom di halaman publik</p></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Nama WBP</th><th>Status Integrasi</th><th>Aksi</th></tr></thead>
              <tbody>
                <% list.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.nama_wbp %></td>
                  <td><%= item.status_integrasi %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/pembinaan?edit=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/pembinaan/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!list.length) { %><tr><td colspan="4" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
